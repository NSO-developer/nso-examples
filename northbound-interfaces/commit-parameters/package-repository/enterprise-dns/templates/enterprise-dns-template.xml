<config-template xmlns="http://tail-f.com/ns/config/1.0"
                 servicepoint="enterprise-dns-servicepoint">
  <devices xmlns="http://tail-f.com/ns/ncs">
    <device>
      <name>{/device}</name>
      <config>
        <sys xmlns="http://example.com/router">
          <dns>
            <search>
              <name>1</name>
              <domain>{/search-domain}</domain>
            </search>
            <server>
              <address>{/dns-server}</address>
            </server>
          </dns>
        </sys>
      </config>
    </device>
  </devices>
</config-template>
