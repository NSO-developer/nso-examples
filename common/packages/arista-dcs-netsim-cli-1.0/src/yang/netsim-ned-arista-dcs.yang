            leaf last-as {
              type uint16;
            }
          }
        }
        container tag {
          presence "tag";
        }
      }
      container comm-list {
        tailf:cli-sequence-commands;
        choice comm-list-choice {
          leaf comm-list-standard {
            tailf:cli-drop-node-name;
            type uint16;
          }
          leaf comm-list-expanded {
            tailf:cli-drop-node-name;
            type uint16;
          }
          leaf comm-list-name {
            tailf:cli-drop-node-name;
            type string;
          }
        }
        leaf delete {
          type empty;
        }
      }
      container extcommunity {
        leaf-list rt {
          tailf:cli-flat-list-syntax;
          type asn-ip-type;
        }
      }
      leaf metric {
        type string;
      }
      leaf origin {
        type enumeration {
          enum egp;
          enum igp;
          enum incomplete;
        }
      }
      container community {
        tailf:cli-compact-syntax;
        choice community-choice {
          leaf-list community-list {
            tailf:cli-flat-list-syntax;
            type string;
          }
          leaf-list community-number {
            tailf:cli-drop-node-name;
            tailf:cli-flat-list-syntax;
            ordered-by user;
            type union {
              type uint32;
              type enumeration {
                enum additive;
                enum delete;
                enum GSHUT;
                enum internet;
                enum local-as;
                enum no-advertise;
                enum no-export;
                enum none;
              }
              type string;
            }
          }
        }
      }
      container ip {
        leaf next-hop {
          type inet:ipv4-address;
        }
      }
      container ipv6 {
        leaf next-hop {
          type inet:ipv6-address;
        }
      }
      leaf local-preference {
        type uint32;
      }
    }
  }
  container system {
    container l1 {
      tailf:cli-add-mode;
      container unsupported {
        container speed {
          leaf action {
            type enumeration {
              enum error;
              enum warn;
            }
          }
        }
        container error-correction {
          leaf action {
            type enumeration {
              enum error;
              enum warn;
            }
          }
        }
      }
    }
    container control-plane {
      tailf:cli-add-mode;
      container ip {
        uses control-plane-access-group-grouping;
      }
      container ipv6 {
        uses control-plane-access-group-grouping;
      }
    }
  }
  container tcpdump {
    list session {
      tailf:cli-suppress-mode;
      tailf:cli-compact-syntax;
      key "name";
      leaf name {
        type string;
      }
      leaf file {
        type string;
      }
    }
  }
  list peer-filter {
    key "name";
    leaf name {
      type string;
    }
    list seq {
      tailf:cli-drop-node-name;
      tailf:cli-suppress-mode;
      key "index";
      leaf index {
        type uint32;
      }
      container match {
        tailf:cli-compact-syntax;
        tailf:cli-sequence-commands;
        leaf as-range {
          type string;
        }
        leaf result {
          type enumeration {
            enum accept;
            enum reject;
          }
        }
      }
    }
  }
  container tacacs-server {
    list host {
      tailf:cli-suppress-mode;
      tailf:cli-delete-when-empty;
      tailf:cli-compact-syntax;
      ordered-by user;
      key "name";
      leaf name {
        type host-type;
      }
      leaf port {
        type uint16;
      }
      leaf timeout {
        type uint16;
      }
      leaf single-connection {
        type empty;
      }
      uses tacacs-server-key-grouping;
      list vrf {
        tailf:cli-suppress-mode;
        tailf:cli-compact-syntax;
        key "name";
        leaf name {
          type string;
        }
        uses tacacs-server-key-grouping;
      }
    }
    container policy {
      container unknown-mandatory-attribute {
        leaf ignore {
          type empty;
        }
      }
    }
    leaf timeout {
      type uint16;
    }
    uses tacacs-server-key-grouping;
  }
  container tap {
    container aggregation {
      tailf:cli-add-mode;
      container mode {
        tailf:cli-compact-syntax;
        container exclusive {
          presence "true";
          container no-errdisable {
            list Ethernet {
              tailf:cli-allow-join-with-key;
              tailf:cli-suppress-mode;
              key "name";
              leaf name {
                type string;
              }
            }
            list Port-Channel {
              tailf:cli-suppress-mode;
              tailf:cli-allow-join-with-key;
              key "name";
              leaf name {
                type string;
              }
            }
          }
        }
      }
      container service-policy {
        container type {
          container tapagg {
            container mac {
              container access-list {
                container match {
                  leaf ip {
                    type empty;
                  }
                }
              }
            }
          }
        }
      }
    }
  }
  list fex {
    key "id";
    leaf id {
      type uint16;
    }
    container pinning {
      leaf max-links {
        type uint16;
      }
    }
    leaf description {
      tailf:cli-multi-value;
      type string;
    }
  }
  container vlan {
    container internal {
      container order {
        choice vlan-internal-order-choice {
          container ascending {
            presence "true";
            uses vlan-internal-order-range-grouping;
          }
          container descending {
            presence "true";
            uses vlan-internal-order-range-grouping;
          }
        }
      }
    }
    list vlan-list {
      tailf:cli-drop-node-name;
      tailf:cli-range-list-syntax;
      key "id";
      leaf id {
        type uint16;
      }
      leaf comment {
        tailf:cli-multi-value;
        type string;
      }
      container ip {
        container igmp {
          container snooping {
            presence "Configures IGMP Snooping";
            leaf explicit-tracking {
              type empty;
            }
            leaf fast-leave {
              type empty;
            }
            leaf last-member-query-interval {
              type uint8;
            }
            leaf link-local-groups-suppression {
              type empty;
            }
            container mrouter {
              container interface {
                list Ethernet {
                  tailf:cli-allow-join-with-key;
                  tailf:cli-suppress-mode;
                  key "name";
                  leaf name {
                    type string;
                  }
                }
                list port-channel {
                  tailf:cli-suppress-mode;
                  tailf:cli-allow-join-with-key;
                  key "name";
                  leaf name {
                    type string;
                  }
                }
              }
            }
            leaf static-group {
              type inet:ipv4-address;
            }
          }
        }
      }
      leaf name {
        tailf:cli-multi-value;
        type string;
      }
      container service-policy {
        container input-map {
          tailf:cli-drop-node-name;
          tailf:cli-sequence-commands;
          tailf:cli-compact-syntax;
          leaf type {
            tailf:cli-optional-in-sequence;
            type enumeration {
              enum qos {
                tailf:code-name "service_policy_input_map_qos";
              }
              enum network-qos {
                tailf:code-name "service_policy_input_map_network_qos";
              }
              enum queuing {
                tailf:code-name "service_policy_input_map_queuing";
              }
            }
          }
          leaf input {
            type string;
          }
          leaf no-stats {
            type empty;
          }
          leaf name {
            tailf:cli-drop-node-name;
            type string;
          }
        }
        container output-map {
          tailf:cli-drop-node-name;
          tailf:cli-sequence-commands;
          tailf:cli-compact-syntax;
          leaf type {
            tailf:cli-optional-in-sequence;
            type enumeration {
              enum qos {
                tailf:code-name "service_policy_output_map_qos";
              }
              enum network-qos {
                tailf:code-name "service_policy_output_map_network_qos";
              }
              enum queuing {
                tailf:code-name "service_policy_output_map_queuing";
              }
            }
          }
          leaf output {
            type string;
          }
          leaf no-stats {
            type empty;
          }
          leaf name {
            tailf:cli-drop-node-name;
            type string;
          }
        }
      }
      leaf shutdown {
        type boolean;
      }
      leaf state {
        type enumeration {
          enum active;
          enum suspend;
        }
      }
      container trunk {
        leaf group {
          type string;
        }
      }
    }
  }

  typedef dscp-type {
    type uint16;
  }

  grouping match-grouping {
    container access-group {
      leaf-list name {
        type string;
      }
    }
    leaf-list cos {
      tailf:cli-range-list-syntax;
      type uint16;
    }
    leaf-list dscp {
      tailf:cli-range-list-syntax;
      type dscp-type;
    }
    container ip {
      leaf access-group {
        type string;
      }
    }
    container ipv6 {
      leaf access-group {
        type string;
      }
    }
    leaf-list precedence {
      tailf:cli-flat-list-syntax;
      type uint8;
    }
    container protocol {
      leaf arp {
        type empty;
      }
      leaf clns_es {
        type empty;
      }
      leaf clns_is {
        type empty;
      }
      leaf dhcp {
        type empty;
      }
      leaf ldp {
        type empty;
      }
      leaf netbios {
        type empty;
      }
    }
    container vlan {
      choice policy-map-match-vlan-choice {
        leaf-list range {
          tailf:cli-drop-node-name;
          tailf:cli-range-list-syntax;
          type uint16;
        }
        leaf-list flat {
          ordered-by user;
          tailf:cli-drop-node-name;
          tailf:cli-flat-list-syntax;
          type string;
        }
      }
    }
  }

  container class-map {
    container type {
      list qos {
        key "name";
        leaf name {
          type string;
        }
        leaf prematch {
          tailf:cli-prefix-key;
          tailf:cli-drop-node-name;
          type enumeration {
            enum match-all;
            enum match-any;
          }
        }
        leaf description {
          tailf:cli-multi-value;
          type string;
        }
        container match {
          uses match-grouping;
        }
      }
      list pbr {
        key "name";
        leaf name {
          type string;
        }
        leaf prematch {
          tailf:cli-prefix-key;
          tailf:cli-drop-node-name;
          type enumeration {
            enum match-all;
            enum match-any;
          }
        }
        leaf description {
          tailf:cli-multi-value;
          type string;
        }
        list class {
          tailf:cli-drop-node-name;
          tailf:cli-suppress-mode;
          tailf:cli-sequence-commands {
            tailf:cli-reset-siblings;
          }
          key "access-group";
          leaf seq {
            tailf:cli-drop-node-name;
            tailf:cli-prefix-key;
            tailf:cli-optional-in-sequence;
            type uint32;
          }
          leaf match {
            tailf:cli-prefix-key;
            type empty;
          }
          leaf ip {
            tailf:cli-prefix-key;
            type empty;
          }
          leaf access-group {
            tailf:cli-expose-key-name;
            type string;
          }
        }
      }
      list tapagg {
        key "name";
        leaf name {
          type string;
        }
        leaf prematch {
          tailf:cli-prefix-key;
          tailf:cli-drop-node-name;
          type enumeration {
            enum match-any;
          }
        }
        choice match-type-choice {
          list ip {
            tailf:cli-drop-node-name;
            tailf:cli-suppress-mode;
            tailf:cli-sequence-commands {
              tailf:cli-reset-siblings;
            }
            key "access-group";
            leaf seq {
              tailf:cli-drop-node-name;
              tailf:cli-prefix-key;
              tailf:cli-optional-in-sequence;
              type uint32;
            }
            leaf match {
              tailf:cli-prefix-key;
              type empty;
            }
            leaf ip {
              tailf:cli-prefix-key;
              type empty;
            }
            leaf access-group {
              tailf:cli-expose-key-name;
              type string;
            }
          }
          list ipv6 {
            tailf:cli-drop-node-name;
            tailf:cli-suppress-mode;
            tailf:cli-sequence-commands {
              tailf:cli-reset-siblings;
            }
            key "access-group";
            leaf seq {
              tailf:cli-drop-node-name;
              tailf:cli-prefix-key;
              tailf:cli-optional-in-sequence;
              type uint32;
            }
            leaf match {
              tailf:cli-prefix-key;
              type empty;
            }
            leaf ipv6 {
              tailf:cli-prefix-key;
              type empty;
            }
            leaf access-group {
              tailf:cli-expose-key-name;
              type string;
            }
          }
          list mac {
            tailf:cli-drop-node-name;
            tailf:cli-suppress-mode;
            tailf:cli-sequence-commands {
              tailf:cli-reset-siblings;
            }
            key "access-group";
            leaf seq {
              tailf:cli-drop-node-name;
              tailf:cli-prefix-key;
              tailf:cli-optional-in-sequence;
              type uint32;
            }
            leaf match {
              tailf:cli-prefix-key;
              type empty;
            }
            leaf mac {
              tailf:cli-prefix-key;
              type empty;
            }
            leaf access-group {
              tailf:cli-expose-key-name;
              type string;
            }
          }
        }
      }
    }
  }

  typedef class-name-type {
    type union {
      type string;
      type enumeration {
        enum class-default;
      }
    }
  }

  grouping policy-map-class-qos-grouping {
    list class {
      ordered-by user;
      key "name";
      leaf name {
        type class-name-type;
      }
      container police {
        choice police-choice {
          container cir {
            tailf:cli-compact-syntax;
            tailf:cli-sequence-commands {
              tailf:cli-reset-siblings;
            }
            leaf value {
              tailf:cli-drop-node-name;
              type uint32;
            }
            leaf units {
              tailf:cli-optional-in-sequence;
              tailf:cli-drop-node-name;
              type enumeration {
                enum bps;
                enum kbps;
                enum mbps;
              }
            }
            leaf bc {
              type uint32;
            }
            leaf bc-units {
              tailf:cli-optional-in-sequence;
              tailf:cli-drop-node-name;
              type enumeration {
                enum bytes;
                enum kbytes;
                enum mbytes;
              }
            }
          }
          container rate {
            tailf:cli-compact-syntax;
            tailf:cli-sequence-commands {
              tailf:cli-reset-siblings;
            }
            leaf value {
              tailf:cli-drop-node-name;
              type uint32;
            }
            leaf units {
              tailf:cli-optional-in-sequence;
              tailf:cli-drop-node-name;
              type enumeration {
                enum bps;
                enum kbps;
                enum mbps;
              }
            }
            leaf burst-size {
              type uint32;
            }
            leaf bs-units {
              tailf:cli-optional-in-sequence;
              tailf:cli-drop-node-name;
              type enumeration {
                enum bytes;
                enum kbytes;
                enum mbytes;
              }
            }
          }
        }
      }
      container set {
        leaf dscp {
          type dscp-type;
        }
        leaf traffic-class {
          type uint8;
        }
      }
    }
  }

  grouping policy-map-class-network-qos-grouping {
    container class {
      container type {
        list network-qos {
          key "name";
          leaf name {
            type class-name-type;
          }
          leaf mtu {
            type uint16;
          }
          leaf multicast-optimize {
            type empty;
          }
          container pause {
            container no-drop {
              presence "Enable no-drop for the CoS";
              tailf:cli-sequence-commands {
                tailf:cli-reset-all-siblings;
              }
              tailf:cli-compact-syntax;
              leaf buffer-size {
                tailf:cli-optional-in-sequence;
                type uint32;
              }
              leaf pause-threshold {
                type uint32;
              }
              leaf resume-threshold {
                type uint32;
              }
              leaf-list pfc-cos {
                tailf:cli-range-list-syntax;
                type uint8;
              }
            }
          }
          container queue-limit {
            tailf:cli-sequence-commands;
            tailf:cli-compact-syntax;
            leaf count {
              tailf:cli-drop-node-name;
              type uint32;
              must '../bytes';
            }
            leaf bytes {
              type empty;
            }
          }
          container set {
            leaf qos {
              type uint8;
            }
          }
        }
      }
    }
  }

  grouping policy-map-class-queuing-grouping {
    container class {
      container type {
        list queuing {
          key "name";
          leaf name {
            type class-name-type;
          }
          container bandwidth {
            leaf percent {
              type uint8;
            }
          }
          leaf priority {
            type empty;
          }
        }
      }
    }
  }

  container control-plane {
    tailf:cli-add-mode;
    container ip {
      uses control-plane-access-group-grouping;
    }
    container ipv6 {
      uses control-plane-access-group-grouping;
    }
    container scale-factor {
      tailf:cli-compact-syntax;
      tailf:cli-sequence-commands {
        tailf:cli-reset-siblings;
      }
      leaf scale {
        tailf:cli-drop-node-name;
        type decimal64 {
          fraction-digits 2;
        }
      }
      leaf module {
        type uint8;
      }
    }
    container service-policy {
      leaf input {
        type string;
      }
    }
  }
  container ntp {
    container server {
      list name {
        tailf:cli-drop-node-name;
        tailf:cli-suppress-mode;
        tailf:cli-compact-syntax;
        key "id";
        leaf id {
          type string;
        }
        container source {
          tailf:cli-flatten-container;
          uses interface-grouping;
        }
        leaf burst {
          tailf:cli-hide-in-submode;
          type empty;
        }
        leaf iburst {
          tailf:cli-hide-in-submode;
          type empty;
        }
        leaf maxpoll {
          tailf:cli-hide-in-submode;
          type uint8;
        }
        leaf minpoll {
          tailf:cli-hide-in-submode;
          type uint8;
        }
        leaf prefer {
          tailf:cli-hide-in-submode;
          type empty;
        }
        leaf version {
          tailf:cli-hide-in-submode;
          type uint8;
        }
        leaf key {
          tailf:cli-hide-in-submode;
          type uint16;
        }
      }
      list vrf {
        tailf:cli-compact-syntax;
        tailf:cli-suppress-mode;
        key "name hostname";
        leaf name {
          type string;
        }
        leaf hostname {
          type string;
        }
        leaf prefer {
          type empty;
        }
        leaf iburst {
          type empty;
        }
        leaf version {
          type uint8;
        }
        leaf maxpoll {
          type uint8;
        }
        container source {
          tailf:cli-flatten-container;
          uses interface-grouping;
        }
      }
    }
    container serve {
      leaf all {
        type empty;
      }
    }
    container source {
      uses interface-grouping;
      container vrf {
        tailf:cli-compact-syntax;
        tailf:cli-sequence-commands {
          tailf:cli-reset-all-siblings;
        }
        leaf name {
          tailf:cli-drop-node-name;
          type string;
        }
        uses interface-grouping;
      }
    }
    container local-interface {
      uses interface-grouping;
      container vrf {
        tailf:cli-compact-syntax;
        tailf:cli-sequence-commands {
          tailf:cli-reset-all-siblings;
        }
        leaf name {
          tailf:cli-drop-node-name;
          type string;
        }
        uses interface-grouping;
      }
    }
  }

  grouping ip-router-ospf-grouping {
    leaf router-id {
      type inet:ipv4-address;
    }
  }

  grouping queue-depth-grouping {
    leaf options {
      tailf:cli-drop-node-name;
      type union {
        type uint32;
        type enumeration {
          enum unlimited;
        }
      }
    }
  }

  grouping ospf-redistribute-match-grouping {
    leaf metric {
      type uint32;
    }
    leaf subnets {
      type empty;
    }
    leaf route-map {
      type string;
    }
    leaf tag {
      type uint32;
    }
  }

  grouping ospf-iso-igrp-redistribute-grouping {
    leaf metric {
      type uint32;
    }
    leaf metric-type {
      type enumeration {
        enum 1;
        enum 2;
      }
    }
    leaf tag {
      type uint32;
    }
    leaf subnets {
      type empty;
    }
  }

  grouping ospf-redistribute-grouping {
    container redist-options {
      tailf:cli-drop-node-name;
      tailf:cli-compact-syntax;
      uses ospf-iso-igrp-redistribute-grouping;
      leaf route-map {
        type string;
      }
    }
  }

  grouping ospf-redistribute-bgp-grouping {
    leaf as-number {
      tailf:cli-drop-node-name;
      type inet:as-number;
    }
    uses ospf-redistribute-grouping;
  }

  typedef ospf-area-type {
    type union {
      type uint32;
      type inet:ipv4-address;
    }
  }

  typedef ospf-metric-type {
    type uint32;
  }

  typedef limit-dc-non-dc-type {
    type union {
      type uint32;
      type enumeration {
        enum disable;
      }
    }
  }

  typedef neighbor-id-type {
    type union {
      type inet:ipv4-address;
      type inet:ipv6-address;
      type string;
    }
  }

  grouping address-family-grouping {
    list neighbor {
      tailf:cli-suppress-mode;
      key "id";
      leaf id {
        type neighbor-id-type;
      }
      leaf description {
        tailf:cli-multi-value;
        type string;
      }
      leaf activate {
        type empty;
      }
      uses route-map-grouping;
      uses default-originate-grouping;
      list prefix-list {
        tailf:cli-suppress-mode;
        tailf:cli-compact-syntax;
        key "in-out";
        leaf name {
          tailf:cli-prefix-key;
          tailf:cli-drop-node-name;
          mandatory true;
          type string;
        }
        leaf in-out {
          type enumeration {
            enum in;
            enum out;
          }
        }
      }
    }
    container aggregate-address {
      tailf:cli-compact-syntax;
      tailf:cli-sequence-commands {
        tailf:cli-reset-all-siblings;
      }
      leaf address {
        tailf:cli-drop-node-name;
        type inet:ipv4-address;
      }
      leaf mask {
        tailf:cli-drop-node-name;
        type inet:ipv4-address;
      }
      leaf advertise-map {
        tailf:cli-break-sequence-commands;
        type string;
      }
      leaf as-set {
        type empty;
      }
      leaf attribute-map {
        type string;
      }
      leaf as-override {
        type empty;
      }
      leaf route-map {
        type string;
      }
      leaf summary-only {
        type empty;
      }
      leaf suppress-map {
        type string;
      }
    }
  }

  uses nexthop-group-grouping;
  container router {
    container bfd {
      tailf:cli-add-mode;
      container interval {
        tailf:cli-compact-syntax;
        tailf:cli-sequence-commands {
