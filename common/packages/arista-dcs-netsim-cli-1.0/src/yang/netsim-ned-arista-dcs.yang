  grouping ipv6-nd-grouping {
    container nd {
      leaf managed-config-flag {
        type empty;
      }
      list prefix {
        tailf:cli-suppress-mode;
        tailf:cli-compact-syntax;
        key "address";
        leaf address {
          type tailf:ipv6-address-and-prefix-length;
        }
        choice ipv6-nd-prefix-choice {
          leaf infinite {
            type empty;
          }
          leaf no-advertise {
            type empty;
          }
          leaf no-autoconfig {
            type empty;
          }
          leaf no-onlink {
            type empty;
          }
        }
      }
      container ra {
        container disabled {
          presence "true";
          leaf all {
            type empty;
          }
        }
        list dns-server {
          tailf:cli-suppress-mode;
          key "address";
          leaf address {
            type union {
              type inet:ipv6-address;
              type string;
            }
          }
          leaf lifetime {
            type uint32;
          }
        }
        container interval {
          container msec {
            tailf:cli-compact-syntax;
            tailf:cli-sequence-commands {
              tailf:cli-reset-siblings;
            }
            leaf max {
              tailf:cli-drop-node-name;
              type uint32;
            }
            leaf min {
              tailf:cli-drop-node-name;
              type uint32;
            }
          }
        }
      }
      leaf redirects {
        type empty;
      }
      leaf router-preference {
        type enumeration {
          enum high;
          enum low;
          enum medium;
        }
      }
    }
