  container dns {
    leaf domain {
      type string;
    }
  }
  container sflow {
    container extension {
      leaf bgp {
        type empty;
      }
    }
    grouping sflow-destination-grouping {
      list destination {
        tailf:cli-suppress-mode;
        tailf:cli-compact-syntax;
        key "id";
        leaf id {
          type string;
        }
        leaf port {
          tailf:cli-drop-node-name;
          type uint16;
        }
      }
    }

    leaf polling-interval {
      type uint16;
    }
    container sample {
      choice sflow-sample-choice {
        leaf dangerous {
          type uint32;
        }
        leaf rate {
          tailf:cli-drop-node-name;
          type uint32;
        }
      }
      container input {
        leaf subinterface {
          type empty;
        }
      }
      leaf rewrite {
        type enumeration {
          enum dscp;
        }
      }
    }
    grouping sflow-source-grouping {
      leaf source {
        type string;
      }
      container source-interface {
        uses interface-grouping;
      }
    }

    uses sflow-destination-grouping;
    uses sflow-source-grouping;
    container vrf {
      uses sflow-destination-grouping;
      uses sflow-source-grouping;
      list vrf {
        tailf:cli-drop-node-name;
        tailf:cli-suppress-mode;
        key "name";
        leaf name {
          type string;
        }
        uses sflow-destination-grouping;
        uses sflow-source-grouping;
      }
    }
    leaf run {
      type empty;
    }
