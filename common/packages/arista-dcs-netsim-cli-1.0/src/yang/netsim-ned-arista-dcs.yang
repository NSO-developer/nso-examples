          container vlan {
            choice vlan-choice {
              leaf-list ids {
                tailf:cli-drop-node-name;
                tailf:cli-range-list-syntax;
                type vlan-list-type;
              }
              leaf fixed {
                tailf:cli-drop-node-name;
                type enumeration {
                  enum all;
                  enum none;
                }
              }
              leaf-list except {
                tailf:cli-range-list-syntax;
                type vlan-list-type;
              }
            }
          }
        }
        container native {
          leaf vlan {
            type uint16;
          }
        }
      }
    }
  }

  grouping fc-settings-grouping {
    container channel-group {
      choice channel-group-choice {
        list port {
          tailf:cli-drop-node-name;
