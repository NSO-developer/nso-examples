  grouping graceful-restart-grouping {
    container graceful-restart {
      leaf restart-time {
        type uint16;
      }
      leaf stalepath-time {
        type uint16;
      }
    }
  }

  grouping bgp-additional-paths-grouping {
    container additional-paths {
      container install {
        presence "true";
        leaf ecmp-primary {
          type empty;
        }
      }
      leaf receive {
        type empty;
      }
      container send {
        presence "true";
        choice additional-paths-choice {
          leaf any {
            type empty;
          }
          leaf backup {
            type empty;
          }
          container ecmp {
            presence "true";
            leaf limit {
              type uint8;
            }
          }
          leaf limit {
            type uint8;
          }
        }
      }
    }
  }

  leaf os-major {
    type uint32;
  }
  leaf os-minor {
    type uint32;
  }
  list alias {
    tailf:cli-suppress-mode;
    key "name";
    leaf name {
      tailf:cli-multi-word-key;
      type string;
    }
  }
  container hardware {
    container access-list {
      container resource {
        container sharing {
          container vlan {
            leaf ipv4 {
              type enumeration {
                enum out;
              }
            }
            leaf ipv6 {
              type enumeration {
                enum out;
              }
            }
          }
        }
      }
      leaf mechanism {
        type enumeration {
          enum algomatch;
          enum none;
          enum tcam;
        }
      }
    }
    container counter {
      container feature {
        container acl {
          leaf in {
            type boolean;
          }
        }
        container ip {
          leaf in {
            type empty;
          }
          container in-layer3 {
            tailf:cli-drop-node-name;
            tailf:cli-compact-syntax;
            tailf:cli-sequence-commands {
              tailf:cli-reset-siblings;
            }
            leaf in {
              type empty;
            }
            leaf layer3 {
              type empty;
            }
          }
          container out-layer3 {
            tailf:cli-drop-node-name;
            tailf:cli-compact-syntax;
            tailf:cli-sequence-commands {
              tailf:cli-reset-siblings;
            }
            leaf out {
              type empty;
            }
            leaf layer3 {
              type empty;
            }
          }
        }
        container subinterface {
          leaf in {
            type empty;
          }
          leaf out {
            type empty;
          }
          container in-layer2 {
            tailf:cli-drop-node-name;
            tailf:cli-compact-syntax;
            tailf:cli-sequence-commands {
              tailf:cli-reset-siblings;
            }
            leaf in {
              type empty;
            }
            leaf layer2 {
              type empty;
            }
          }
          container out-layer2 {
            tailf:cli-drop-node-name;
            tailf:cli-compact-syntax;
            tailf:cli-sequence-commands {
              tailf:cli-reset-siblings;
            }
            leaf out {
              type empty;
            }
            leaf layer2 {
              type empty;
            }
          }
        }
        container traffic-policy {
          leaf cpu {
            type empty;
          }
          leaf in {
            type empty;
          }
          leaf out {
            type empty;
          }
        }
      }
    }
    list speed-group {
      tailf:cli-suppress-mode;
      tailf:cli-allow-join-with-key;
      key "id";
      leaf id {
        type uint16;
      }
      leaf serdes {
        type enumeration {
          enum 10g;
          enum 25g;
          enum 50g;
        }
      }
    }
    container tcam-mode {
      tailf:cli-drop-node-name;
      container tcam {
        tailf:cli-add-mode;
        list profile {
          key "name";
          leaf name {
            type string;
          }
          list feature {
            key "name";
            leaf name {
              tailf:cli-multi-word-key;
              type string;
            }
            leaf sequence {
              type uint16;
            }
            container key {
              container size {
                leaf limit {
                  type enumeration {
                    enum 160;
                    enum 320;
                    enum 80;
                  }
                }
              }
              leaf-list field {
