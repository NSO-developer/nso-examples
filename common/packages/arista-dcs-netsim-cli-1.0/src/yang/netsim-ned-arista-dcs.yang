          container linkstatus {
            tailf:alt-name "link-status";
            presence "UPDOWN and CHANGE messages";
            leaf default {
              type empty;
            }
          }
          container trunk-status {
            presence "TRUNK status messages";
            leaf default {
              type empty;
            }
          }
        }
        leaf link-status {
          type enumeration {
            enum yes;
            enum no;
            enum use-global;
          }
        }
        container storm-control {
          leaf discards {
            type enumeration {
              enum yes;
              enum no;
              enum use-global;
            }
          }
        }
      }
    }
  }

  grouping management-ssh-access-group-grouping {
    list access-group {
      tailf:cli-suppress-mode;
      tailf:cli-compact-syntax;
      key "name";
      leaf name {
        type string;
      }
      leaf inout {
        tailf:cli-drop-node-name;
        type enumeration {
          enum in;
        }
      }
      list vrf {
        tailf:cli-suppress-mode;
        tailf:cli-compact-syntax;
        key "name";
        leaf name {
          type string;
        }
        leaf inout {
          tailf:cli-drop-node-name;
          type enumeration {
            enum in;
          }
        }
      }
    }
  }

  grouping interface-vrrp-grouping {
    list vrrp {
      tailf:cli-suppress-mode;
      tailf:cli-compact-syntax;
      key "id";
      leaf id {
        type uint8;
      }
      container authentication {
        tailf:cli-compact-syntax;
        leaf text {
          type string;
        }
      }
      container preempt {
        container delay {
          tailf:cli-compact-syntax;
          leaf minimum {
            type uint16;
          }
          leaf reload {
            type uint16;
          }
        }
      }
      container timers {
        container delay {
          leaf reload {
            type uint16;
          }
        }
      }
      choice vrrp-priority-choice {
        leaf priority {
          type uint8;
        }
        leaf priority-level {
          type uint8;
        }
      }
      container peer {
        container authentication {
          container ietf-md5 {
            tailf:cli-compact-syntax;
            tailf:cli-sequence-commands;
            container key-string {
              tailf:cli-compact-syntax;
              tailf:cli-sequence-commands;
              leaf encryption {
                tailf:cli-drop-node-name;
                tailf:cli-optional-in-sequence;
                type enumeration {
                  enum 0;
                  enum 7;
                }
              }
              leaf password {
                tailf:cli-drop-node-name;
                type string;
              }
            }
          }
        }
      }
      choice vrrp-ip-choice {
        container ip {
          leaf version {
            type uint8;
          }
          leaf primary {
            tailf:cli-drop-node-name;
            type inet:ipv4-address;
          }
          container secondary {
            tailf:cli-drop-node-name;
            tailf:cli-compact-syntax;
            tailf:cli-sequence-commands {
              tailf:cli-reset-siblings;
            }
            leaf address {
              tailf:cli-drop-node-name;
              type inet:ipv4-address;
            }
            leaf secondary {
              type empty;
            }
          }
        }
        container ipv4 {
          leaf version {
            type uint8;
          }
          leaf primary {
            tailf:cli-drop-node-name;
            type inet:ipv4-address;
          }
          list address-secondary {
            tailf:cli-drop-node-name;
            tailf:cli-compact-syntax;
            tailf:cli-suppress-mode;
            key "address";
            leaf address {
              type inet:ipv4-address;
            }
            leaf secondary {
              type empty;
            }
          }
        }
      }
      list ipv6 {
        tailf:cli-suppress-mode;
        key "address";
        leaf address {
          type inet:ipv6-address;
        }
      }
      list tracked-object {
        tailf:cli-suppress-mode;
        key "name";
        leaf name {
          type string;
        }
        leaf decrement {
          type uint8;
        }
        leaf shutdown {
          type empty;
        }
      }
    }
  }

  grouping snmp-trap-link-status-grouping {
    container snmp {
      container trap {
        choice trap-choice {
          leaf link-status {
            type boolean;
          }
          leaf link-change {
            type boolean;
          }
        }
      }
    }
  }

  grouping interface-ip-proxy-arp-grouping {
    leaf local-proxy-arp {
      type empty;
    }
    leaf proxy-arp {
      type empty;
    }
  }

  grouping storm-control-level-grouping {
    container level {
      choice storm-control-level-choice {
        leaf pps {
          type uint32;
        }
        leaf maximum-bandwidth {
          tailf:cli-drop-node-name;
          type decimal64 {
            fraction-digits 2;
          }
        }
      }
    }
  }

  grouping storm-control-grouping {
    container storm-control {
      container broadcast {
        presence "Broadcast";
        tailf:cli-delete-when-empty;
        uses storm-control-level-grouping;
      }
      container unicast {
        presence "Unicast";
        tailf:cli-delete-when-empty;
        uses storm-control-level-grouping;
      }
      container multicast {
        presence "Multicast";
        tailf:cli-delete-when-empty;
        uses storm-control-level-grouping;
      }
      container unknown-unicast {
        presence "Unknown-unicast";
        tailf:cli-delete-when-empty;
        uses storm-control-level-grouping;
      }
    }
  }

  grouping username-sshkey-grouping {
    leaf file {
      type string;
    }
    list secondary {
      tailf:cli-suppress-mode;
      key "name";
      leaf name {
        tailf:cli-multi-word-key;
        type string;
      }
    }
    leaf sshkey {
      tailf:cli-drop-node-name;
      tailf:cli-multi-value;
      type string;
    }
  }

  grouping snmp-server-auth-grouping {
    leaf auth {
      type enumeration {
        enum md5;
        enum sha;
        enum sha224;
        enum sha256;
        enum sha384;
        enum sha512;
      }
    }
    leaf auth-password {
      tailf:cli-drop-node-name;
      type string;
    }
    leaf priv {
      tailf:cli-optional-in-sequence;
      type enumeration {
        enum aes;
        enum des;
        enum aes192;
        enum aes256;
      }
    }
    leaf priv-password {
      tailf:cli-drop-node-name;
      type string;
    }
  }

  grouping snmp-server-user-grouping {
    choice security-model {
      leaf v1 {
        type empty;
      }
      leaf v2c {
        type empty;
      }
      case v3 {
        container v3 {
          tailf:cli-compact-syntax;
          tailf:cli-flatten-container;
          tailf:cli-sequence-commands {
            tailf:cli-reset-siblings;
          }
          leaf localized {
            tailf:cli-optional-in-sequence;
            type empty;
          }
          leaf engineID {
            tailf:cli-drop-node-name;
            tailf:cli-optional-in-sequence;
            type string;
          }
          uses snmp-server-auth-grouping;
        }
      }
    }
  }

  grouping control-plane-access-group-grouping {
    container access-group {
      container non-vrf {
        tailf:cli-drop-node-name;
        tailf:cli-compact-syntax;
        tailf:cli-sequence-commands;
        leaf name {
          tailf:cli-drop-node-name;
          type string;
        }
        leaf inout {
          tailf:cli-drop-node-name;
          type enumeration {
            enum in;
          }
        }
      }
      list vrf {
        tailf:cli-drop-node-name;
        tailf:cli-suppress-mode;
        tailf:cli-compact-syntax;
        tailf:cli-delete-when-empty;
        key "vrf";
        leaf name {
          tailf:cli-prefix-key;
          tailf:cli-drop-node-name;
          type string;
        }
        leaf vrf {
          tailf:cli-expose-key-name;
          type string;
        }
        leaf inout {
          tailf:cli-drop-node-name;
          type enumeration {
            enum in;
          }
        }
      }
    }
  }

  grouping logging-host-grouping {
    leaf port {
