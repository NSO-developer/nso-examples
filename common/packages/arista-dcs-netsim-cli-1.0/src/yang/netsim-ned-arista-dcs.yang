          list profile {
            key "name";
            leaf name {
              type string;
            }
          }
        }
      }
    }
  }
  container port-channel {
    container load-balance {
      container sand {
        leaf profile {
          type string;
        }
      }
    }
  }
  container platform {
    container trident {
      container forwarding-table {
        leaf partition {
          type enumeration {
            enum 0;
            enum 1;
            enum 2;
            enum 3;
            enum 4;
          }
        }
      }
    }
    container sand {
      container lag {
        leaf hardware-only {
          type empty;
        }
      }
    }
  }
  list role {
    key "name";
    leaf name {
      type string;
    }
    leaf comment {
      tailf:cli-multi-value;
      type string;
    }
    list role-list-rule {
      tailf:cli-suppress-mode;
      tailf:cli-delete-when-empty;
      tailf:cli-drop-node-name;
      tailf:cli-compact-syntax;
      key "seq";
      leaf seq {
        tailf:cli-suppress-range;
        type uint16;
      }
      leaf rule {
        tailf:cli-multi-value;
        tailf:cli-drop-node-name;
        type string;
      }
    }
  }
  container interface {
    list Ethernet {
      tailf:cli-allow-join-with-key;
      key "name";
      leaf name {
        type string;
      }
      uses ethernet-settings-grouping;
      uses interface-service-policy-grouping;
      uses arp-timeout-grouping;
      container pim {
        container ipv4 {
          container neighbor {
            leaf filter {
              type string;
            }
          }
          leaf bidirectional {
            type empty;
          }
          leaf border-router {
            type empty;
          }
          leaf sparse-mode {
            type empty;
          }
          leaf dr-priority {
            type uint32;
          }
          leaf bfd {
            type boolean;
          }
        }
      }
      uses interface-vrrp-grouping;
      container lacp {
        leaf port-priority {
          type uint16;
        }
        leaf rate {
          type enumeration {
            enum fast;
            enum normal;
          }
        }
        leaf timer {
          type enumeration {
            enum fast;
            enum normal;
          }
        }
      }
      container link-debounce {
        container time {
          tailf:cli-compact-syntax;
          tailf:cli-sequence-commands;
          leaf up-down {
            tailf:cli-drop-node-name;
            type uint16;
          }
          leaf down-only {
            tailf:cli-drop-node-name;
            type uint16;
          }
        }
      }
      container poe {
        leaf disabled {
          type empty;
        }
        container shutdown {
          leaf action {
            type enumeration {
              enum maintain;
              enum power-off;
            }
          }
        }
      }
      container transceiver {
        container power {
          leaf ignore {
            type empty;
          }
        }
        container application {
          leaf override {
            type union {
              type enumeration {
                enum 100gbase-srbd;
              }
              type uint8;
            }
          }
        }
        leaf frequency {
          type decimal64 {
            fraction-digits 3;
          }
        }
        container transmitter {
          leaf signal-power {
            type decimal64 {
              fraction-digits 2;
            }
          }
        }
      }
    }
    list Loopback {
      tailf:cli-allow-join-with-key;
      key "name";
      leaf name {
        type uint16;
      }
      uses loopback-settings-grouping;
      uses arp-timeout-grouping;
    }
    list Management {
      tailf:cli-allow-join-with-key;
      key "name";
      leaf name {
        type string;
      }
      uses mgmt-settings-grouping;
      container ipv6 {
        uses mgmt-settings-ipv6-grouping;
      }
      uses arp-timeout-grouping;
    }
    list Port-Channel {
      tailf:cli-allow-join-with-key;
      key "name";
      leaf name {
        type string;
      }
      leaf comment {
        tailf:cli-multi-value;
        type string;
      }
      uses port-channel-settings-grouping;
      uses interface-service-policy-grouping;
      uses arp-timeout-grouping;
      uses interface-vrrp-grouping;
    }
    list Vlan {
      tailf:cli-allow-join-with-key;
      key "id";
      leaf id {
        type uint16;
      }
      leaf name {
        type string;
      }
      container bfd {
        container interval {
          tailf:cli-compact-syntax;
          tailf:cli-sequence-commands {
            tailf:cli-reset-siblings;
          }
          leaf rate {
            tailf:cli-drop-node-name;
            type uint16;
          }
          leaf min-rx {
            type uint16;
          }
          leaf multiplier {
            type uint8;
          }
        }
      }
      uses mgmt-settings-grouping {
        augment "ip/address" {
          leaf virtual {
            type tailf:ipv4-address-and-prefix-length;
          }
        }
        augment "ip/pim" {
          leaf query-interval {
            type uint16;
          }
          leaf bfd-instance {
            type empty;
          }
        }
        augment "ip" {
          uses interface-ip-nat-grouping;
        }
        augment "ip/igmp" {
          container host-proxy {
            list group {
              tailf:cli-drop-node-name;
              tailf:cli-suppress-mode;
              key "address";
              leaf address {
                type inet:ipv4-address;
              }
              leaf disable {
                type empty;
              }
            }
          }
        }
      }
      container ospfv3 {
        container ipv6 {
          leaf area {
            type ospf-area-type;
          }
        }
        leaf passive-interface {
          type boolean;
        }
      }
      container pim {
        container ipv4 {
          container local-interface {
            uses interface-grouping;
          }
          container hello {
            leaf interval {
              type uint16;
            }
          }
          leaf sparse-mode {
            type empty;
          }
          leaf dr-priority {
            type uint32;
          }
          leaf bfd {
            type empty;
          }
        }
      }
      container rip {
        container authentication {
          container algorithm {
            container md5 {
              container key-id {
                tailf:cli-flatten-container;
                tailf:cli-sequence-commands;
                tailf:cli-compact-syntax;
                leaf value {
                  tailf:cli-drop-node-name;
                  type uint8;
                }
                container key {
                  tailf:cli-flatten-container;
                  tailf:cli-compact-syntax;
                  tailf:cli-sequence-commands;
                  leaf encryption {
                    tailf:cli-drop-node-name;
                    tailf:cli-optional-in-sequence;
                    type enumeration {
                      enum 0;
                      enum 7;
                    }
                  }
                  leaf password {
                    tailf:cli-drop-node-name;
                    type string;
                  }
                }
              }
            }
          }
        }
      }
      container ipv6 {
        uses mgmt-settings-ipv6-grouping;
        container address-virtual {
          tailf:cli-drop-node-name;
          container address {
            list virtual {
              tailf:cli-suppress-mode;
              key "prefix";
              leaf prefix {
                type tailf:ipv6-address-and-prefix-length;
              }
            }
          }
        }
        container dhcp {
          container relay {
            list destination {
              tailf:cli-suppress-mode;
              key "address";
              leaf address {
                type inet:ipv6-address;
              }
            }
          }
        }
        list virtual-router {
          tailf:cli-suppress-mode;
          key "address";
          leaf address {
            tailf:cli-expose-key-name;
            type inet:ipv6-address;
          }
        }
      }
      uses interface-service-policy-grouping;
      uses arp-timeout-grouping;
    }
    list Vxlan {
      tailf:cli-allow-join-with-key;
      key "id";
      leaf id {
        type uint16;
      }
      leaf description {
        tailf:cli-multi-value;
        type string;
      }
      container telemetry {
        container inband {
          container profile {
            leaf vxlan {
              type string;
            }
          }
        }
      }
      leaf shutdown {
        type empty;
      }
      container vxlan {
        leaf learn-restrict {
          type enumeration {
            enum any;
            enum flood;
            enum vtep;
          }
        }
        container multicast {
          container routing {
            leaf ipv4 {
              type empty;
            }
          }
        }
        leaf multicast-group {
          type inet:ipv4-address;
        }
        container source-interface {
          leaf Loopback {
            tailf:cli-drop-node-name;
            type string;
          }
        }
        leaf udp-port {
          type uint16;
        }
        container virtual-router {
          container encapsulation {
            container mac-address {
              choice encapsulation-mac-address-choice {
                leaf mlag-system-id {
                  type empty;
                }
                leaf ethernet-address {
                  tailf:cli-drop-node-name;
                  type string;
                }
              }
            }
          }
        }
        container vlan {
          list vlan-vni {
            tailf:cli-drop-node-name;
            tailf:cli-compact-syntax;
            tailf:cli-suppress-mode;
            tailf:cli-delete-when-empty;
            key "id";
            leaf id {
              type uint16;
            }
            leaf vni {
              mandatory true;
              type uint32;
            }
          }
          list vlan-list {
            tailf:cli-drop-node-name;
            tailf:cli-suppress-mode;
            tailf:cli-range-list-syntax;
            tailf:cli-delete-when-empty;
            key "id";
            leaf id {
              type uint16;
            }
            container flood {
              leaf-list vtep {
                tailf:cli-flat-list-syntax;
                type inet:ipv4-address;
              }
            }
            container multicast {
              leaf group {
                type inet:ipv4-address;
              }
            }
          }
        }
        list vrf {
          tailf:cli-suppress-mode;
          tailf:cli-delete-when-empty;
          key "name";
          leaf name {
            type string;
          }
          container multicast {
            container group {
              leaf ip {
                tailf:cli-drop-node-name;
                type inet:ipv4-address;
              }
              list overlay {
                tailf:cli-suppress-mode;
                tailf:cli-compact-syntax;
                tailf:cli-sequence-commands {
                  tailf:cli-reset-siblings;
                }
                key "address";
                leaf address {
                  type inet:ipv4-address;
                }
                leaf encap {
                  type inet:ipv4-address;
                }
                leaf immediate {
                  type empty;
                }
              }
            }
          }
          leaf vni {
            type uint32;
          }
        }
      }
    }
    container defaults {
      tailf:cli-add-mode;
      leaf mtu {
        type uint32;
      }
    }
  }
  container directflow {
    tailf:cli-add-mode;
    leaf shutdown {
      type boolean;
    }
    list flow {
      key "name";
      leaf name {
        type string;
      }
      container match {
        container input {
          uses directflow-interface-grouping;
        }
        container destination {
          leaf mac {
            type string;
          }
        }
      }
      container action {
        container output {
