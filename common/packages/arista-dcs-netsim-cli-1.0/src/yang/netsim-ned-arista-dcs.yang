    leaf facility {
      type enumeration {
        enum auth;
        enum cron;
        enum daemon;
        enum kern;
        enum local0;
        enum local1;
        enum local2;
        enum local3;
        enum local4;
        enum local5;
        enum local6;
        enum local7;
        enum lpr;
        enum mail;
        enum news;
        enum sys10;
        enum sys11;
        enum sys12;
        enum sys13;
        enum sys14;
        enum sys9;
        enum syslog;
        enum user;
        enum uucp;
      }
    }
    container source-interface {
      uses interface-grouping;
    }
    list vrf {
      tailf:cli-suppress-mode;
      tailf:cli-compact-syntax;
      key "name";
      leaf name {
        type string;
      }
      list host {
        tailf:cli-suppress-mode;
        tailf:cli-compact-syntax;
        key "hostname";
        leaf hostname {
          type string;
        }
        uses logging-host-grouping;
      }
      container source-interface {
        uses interface-grouping;
