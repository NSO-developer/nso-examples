        type string;
      }
      leaf code {
        type enumeration {
          enum all;
        }
      }
    }
  }

  grouping directflow-interface-grouping {
    container interface {
      list Et {
        tailf:cli-suppress-mode;
        tailf:cli-range-list-syntax;
        tailf:cli-allow-join-with-key;
        key "id";
