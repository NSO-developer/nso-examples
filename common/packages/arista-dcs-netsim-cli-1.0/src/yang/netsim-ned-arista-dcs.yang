    container prefix-list {
      list prefixes {
        tailf:cli-drop-node-name;
        key "name";
        leaf name {
          type string;
        }
        leaf comment {
          tailf:cli-multi-value;
          type string;
        }
        list seq {
          tailf:cli-suppress-mode;
          key "no";
          leaf no {
            type uint32;
          }
          container deny {
            tailf:cli-compact-syntax;
            tailf:cli-flatten-container;
            tailf:cli-sequence-commands {
              tailf:cli-reset-all-siblings;
            }
            leaf ip {
              tailf:cli-drop-node-name;
              type inet:ipv6-prefix;
            }
            choice gele-eq-choice {
              container ge-le {
                tailf:cli-drop-node-name;
                tailf:cli-compact-syntax;
                tailf:cli-flatten-container;
                leaf ge {
                  tailf:cli-break-sequence-commands;
                  type uint8;
                }
                leaf le {
                  type uint8;
                }
              }
              leaf eq {
                type uint8;
              }
            }
          }
          container permit {
            tailf:cli-compact-syntax;
            tailf:cli-flatten-container;
            tailf:cli-sequence-commands {
              tailf:cli-reset-all-siblings;
            }
            leaf ip {
              tailf:cli-drop-node-name;
              type inet:ipv6-prefix;
            }
            choice gele-eq-choice {
              container ge-le {
                tailf:cli-drop-node-name;
                tailf:cli-compact-syntax;
                tailf:cli-flatten-container;
                leaf ge {
                  tailf:cli-break-sequence-commands;
                  type uint8;
                }
                leaf le {
                  type uint8;
                }
              }
              leaf eq {
                type uint8;
              }
            }
          }
        }
      }
    }
    list host {
      key "name ip";
      leaf name {
        type string;
      }
      leaf ip {
        type inet:ipv6-address;
      }
    }
    container route {
      list vrf {
        tailf:cli-suppress-mode;
        tailf:cli-delete-when-empty;
        tailf:cli-compact-syntax;
        key "name";
        leaf name {
          type string;
        }
        uses ipv6-route-grouping;
      }
      container no-vrf {
        tailf:cli-drop-node-name;
        uses ipv6-route-grouping;
      }
    }
    container unicast-routing {
      presence "true";
      leaf vrf {
        type string;
      }
    }
  }
  container logging {
    list host {
      tailf:cli-suppress-mode;
      tailf:cli-compact-syntax;
      key "id";
      leaf id {
        type string;
      }
