        list address {
          tailf:cli-drop-node-name;
          tailf:cli-suppress-mode;
          tailf:cli-compact-syntax;
          key "ip";
          leaf ip {
            type inet:ipv4-address;
          }
          leaf override {
            type empty;
          }
        }
        list address-acl {
          tailf:cli-drop-node-name;
          tailf:cli-suppress-mode;
          tailf:cli-compact-syntax;
          key "ip access-list";
          leaf ip {
            type inet:ipv4-address;
          }
          leaf access-list {
            tailf:cli-expose-key-name;
            type string;
          }
          leaf override {
            type empty;
          }
        }
      }
    }
  }

  grouping protocol-icmp-grouping {
    container icmp-code-all {
      tailf:cli-drop-node-name;
      tailf:cli-compact-syntax;
