        tailf:cli-delete-when-empty;
        tailf:cli-compact-syntax;
        key "name";
        leaf name {
          type aaa-accounting-name-type;
        }
        uses accounting-action-type-grouping;
        leaf logging {
          type empty;
        }
        leaf group {
          type aaa-group-type;
        }
