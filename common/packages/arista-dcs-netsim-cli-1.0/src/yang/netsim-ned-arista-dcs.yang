module netsim-ned-arista-dcs {
  namespace "http://tail-f.com/ned/arista-dcs";
  prefix dcs;

  import tailf-common {
    prefix tailf;
  }
  import ietf-inet-types {
    prefix inet;
  }

  revision 2026-03-27;

  typedef ip-mask {
    type string;
  }

  typedef mac-address-type {
    type union {
      type string;
      type string;
      type string;
      type string;
    }
  }

  typedef mac-address-type2 {
    type union {
      type string;
      type string;
      type string;
      type string;
    }
  }

  typedef vlan-list-type {
    type uint16;
  }

  typedef vrf-member-type {
    type union {
      type string;
      type enumeration {
        enum management;
      }
    }
  }

  typedef logging-level-type {
    type enumeration {
      enum alerts;
      enum critical;
      enum debugging;
      enum emergencies;
      enum errors;
      enum informational;
      enum notifications;
      enum warnings;
    }
  }

  typedef aaa-group-type {
    type union {
      type string;
      type enumeration {
        enum radius;
        enum tacacs+;
      }
    }
  }

  typedef aaa-authorization-name-type {
    type enumeration {
      enum default;
    }
  }

  typedef aaa-accounting-name-type {
    type enumeration {
      enum default;
      enum console;
    }
  }

  typedef std-ip-acl-type {
    type union {
      type uint16;
      type uint16;
      type string;
    }
  }

  typedef authentication-level-type {
    type enumeration {
      enum level-1;
      enum level-2;
    }
  }

  typedef rd-type {
    type string;
  }

  typedef vpn-id-type {
    type string;
  }

  typedef host-type {
    type union {
      type inet:ip-address;
      type inet:domain-name;
    }
  }

  typedef asn-ip-type {
    type string;
  }

  typedef hhmm-type {
    type string;
  }

  typedef weekday-type {
    type enumeration {
      enum Mon;
      enum Tue;
      enum Wed;
      enum Thu;
      enum Fri;
      enum Sat;
      enum Sun;
    }
  }

  typedef month-type {
    type enumeration {
      enum Jan;
      enum Feb;
      enum Mar;
      enum Apr;
      enum May;
      enum Jun;
      enum Jul;
      enum Aug;
      enum Sep;
      enum Oct;
      enum Nov;
      enum Dec;
    }
  }

  typedef std-acl-type {
    type union {
      type uint16;
      type uint16;
      type string;
    }
  }

  typedef ext-acl-type {
    type union {
      type uint16;
      type uint16;
      type string;
    }
  }

  typedef exp-acl-type {
    type union {
      type uint16;
      type uint16;
      type string;
    }
  }

  typedef mdt-data-list-type {
    type union {
      type uint16;
      type uint16;
      type string;
    }
  }

  typedef ldp-discovery-address-type {
    type union {
      type enumeration {
        enum interface {
          tailf:code-name "ldp_interface";
        }
      }
      type inet:ipv4-address;
    }
  }

  typedef mst-cost-type {
    type union {
      type uint32;
      type enumeration {
        enum auto {
          tailf:code-name "mst_cost_type_auto";
        }
      }
    }
  }

  typedef spanning-tree-cost-type {
    type union {
      type uint32;
      type enumeration {
        enum auto {
          tailf:code-name "spanning-tree-cost-type-auto";
        }
      }
    }
  }

  typedef precedence-type {
    type union {
      type uint16;
      type enumeration {
        enum critical;
        enum flash;
        enum flash-override;
        enum immediate;
        enum internet {
          tailf:code-name "prec_internet";
        }
        enum network;
        enum priority {
          tailf:code-name "prec_priority";
        }
        enum routine;
      }
    }
  }

  typedef precedence-type2 {
    type union {
      type uint16;
      type enumeration {
        enum rsvp {
          tailf:code-name "prec_rsvp";
        }
      }
    }
  }

  typedef police-action-old-type {
    type enumeration {
      enum drop {
        tailf:code-name "police_drop";
      }
      enum set-clp-transmit;
      enum set-discard-class-transmit;
      enum set-dscp-transmit;
      enum set-frde-transmit;
      enum set-mpls-exp-imposition-transmit;
      enum set-mpls-exp-topmost-transmit;
      enum set-prec-transmit;
      enum set-qos-transmit;
      enum transmit {
        tailf:code-name "police_transmit";
      }
    }
  }

  typedef ipv4-prefix {
    type string;
  }

  typedef access-list-standard-id-type {
    type union {
      type default-access-list-standard-id-type;
      type string;
    }
  }

  typedef default-access-list-standard-id-type {
    type union {
      type uint8;
      type uint16;
    }
  }

  typedef access-list-in-out-type {
    type enumeration {
      enum in;
      enum out;
    }
  }

  typedef redist-ospf-external-type {
    type enumeration {
      enum 1;
      enum 2;
    }
  }

  typedef bgp-as-no-type {
    type union {
      type uint32;
      type string;
    }
  }

  grouping interface-grouping {
    choice interface-choice {
      leaf Ethernet {
        tailf:cli-allow-join-with-value;
        type string;
      }
      leaf Loopback {
        tailf:cli-allow-join-with-value;
        type uint16;
      }
      leaf Management {
        tailf:cli-allow-join-with-value;
        type string;
      }
      leaf Null0 {
        type empty;
      }
      leaf Port-Channel {
        tailf:cli-allow-join-with-value;
        type string;
      }
      leaf Vlan {
        tailf:cli-allow-join-with-value;
        type uint16;
      }
      leaf Vxlan {
        tailf:cli-allow-join-with-value;
        type uint16;
      }
    }
  }

  grouping interface-no-content-on-delete-grouping {
    choice interface-choice {
      leaf Ethernet {
        tailf:cli-allow-join-with-value;
        type string;
      }
      leaf Loopback {
        tailf:cli-allow-join-with-value;
        type uint16;
      }
      leaf Management {
        tailf:cli-allow-join-with-value;
        type string;
      }
      leaf Null0 {
        type empty;
      }
      leaf Port-Channel {
        tailf:cli-allow-join-with-value;
        type string;
      }
      leaf Vlan {
        tailf:cli-allow-join-with-value;
        type uint16;
      }
      leaf Vxlan {
        tailf:cli-allow-join-with-value;
        type uint16;
      }
    }
  }

  grouping ip-route-grouping {
    list ip-route-interface-list {
      tailf:cli-drop-node-name;
      tailf:cli-suppress-mode;
      tailf:cli-delete-when-empty;
      tailf:cli-compact-syntax;
      key "prefix interface forwarding-address";
      leaf prefix {
        type ip-mask;
      }
      leaf interface {
        type string;
      }
      leaf forwarding-address {
        type inet:ipv4-address;
      }
      uses ip-route-options-grouping;
    }
    list ip-route-list {
      tailf:cli-drop-node-name;
      tailf:cli-suppress-mode;
      tailf:cli-delete-when-empty;
      tailf:cli-compact-syntax;
      key "prefix forwarding-address";
      leaf prefix {
        type ip-mask;
      }
      leaf forwarding-address {
        type inet:ipv4-address;
      }
      uses ip-route-options-grouping;
    }
    list ip-route-list-interface-only {
      tailf:cli-drop-node-name;
      tailf:cli-suppress-mode;
      tailf:cli-delete-when-empty;
      tailf:cli-compact-syntax;
      key "prefix interface";
      leaf prefix {
        type ip-mask;
      }
      leaf interface {
        type string;
      }
      uses ip-route-options-grouping;
    }
  }

  grouping ip-community-list-standard-grouping {
    container deny {
      presence "Specify community to reject";
      list deny-list {
        tailf:cli-drop-node-name;
        tailf:cli-suppress-mode;
        key "expr";
        leaf expr {
          tailf:cli-multi-word-key;
          type string;
        }
      }
    }
    container permit {
      presence "Specify community to accept";
      list permit-list {
        tailf:cli-drop-node-name;
        tailf:cli-suppress-mode;
        key "expr";
        leaf expr {
          tailf:cli-multi-word-key;
          type string;
        }
      }
    }
  }

  grouping switchport-interface-grouping {
    container switchport {
      container mac {
        container address {
          leaf learning {
            type boolean;
          }
        }
      }
      container access {
        leaf vlan {
          type uint16;
        }
      }
      leaf block {
        type enumeration {
          enum multicast {
            tailf:code-name "switchport_block_multicast";
          }
          enum unicast {
            tailf:code-name "switchport_block_unicast";
          }
        }
      }
      leaf description {
        tailf:cli-multi-value;
        type string;
      }
      leaf host {
        type empty;
      }
      leaf mode {
        type union {
          type enumeration {
            enum access {
              tailf:code-name "switchport_mode_access";
            }
            enum fex-fabric;
            enum trunk {
              tailf:code-name "switchport_mode_trunk";
            }
            enum tap;
            enum tool;
          }
          type string;
        }
      }
      container mode-container {
        tailf:cli-drop-node-name;
        container mode {
          container trunk {
            leaf phone {
              type empty;
            }
          }
        }
      }
      container phone {
        leaf vlan {
          type uint16;
        }
        leaf trunk {
          type enumeration {
            enum tagged;
            enum untagged;
          }
        }
      }
      container port-security {
        leaf maximum {
          type uint16;
        }
        container mac-address {
          leaf maximum {
            type union {
              type enumeration {
                enum disabled;
              }
              type uint32;
            }
          }
        }
        container violation {
          tailf:cli-compact-syntax;
          tailf:cli-sequence-commands {
            tailf:cli-reset-siblings;
          }
          leaf mode {
            tailf:cli-drop-node-name;
            type enumeration {
              enum protect;
              enum shutdown;
            }
          }
          leaf log {
            type empty;
          }
        }
      }
      leaf monitor {
        type empty;
      }
      container tap {
        container allowed {
          leaf-list vlan {
            tailf:cli-range-list-syntax;
            type uint16;
          }
        }
        container default {
          leaf-list group {
            tailf:cli-flat-list-syntax;
            type string;
          }
        }
        leaf identity {
          type uint16;
        }
        container native {
          leaf vlan {
            type uint16;
          }
        }
      }
      container tool {
        leaf identity {
          type enumeration {
            enum dot1q;
          }
        }
        leaf-list group {
          tailf:cli-flat-list-syntax;
          type string;
        }
      }
      container trunk {
        container allowed {
          container vlan {
            choice vlan-choice {
              leaf-list ids {
                tailf:cli-drop-node-name;
                tailf:cli-range-list-syntax;
                type vlan-list-type;
              }
              leaf fixed {
                tailf:cli-drop-node-name;
                type enumeration {
                  enum all;
                  enum none;
                }
              }
              leaf-list except {
                tailf:cli-range-list-syntax;
                type vlan-list-type;
              }
            }
          }
        }
        list group {
          tailf:cli-suppress-mode;
          key "name";
          leaf name {
            type string;
          }
        }
        container native {
          container vlan {
            leaf vlan {
              tailf:cli-drop-node-name;
              type uint16;
            }
            leaf tag {
              type empty;
            }
          }
        }
      }
      container vlan {
        container mapping {
          list map {
            tailf:cli-drop-node-name;
            tailf:cli-suppress-mode;
            key "from to";
            leaf from {
              type uint16;
            }
            leaf to {
              type uint16;
            }
          }
        }
        container translation {
          list from-to {
            tailf:cli-suppress-mode;
            tailf:cli-compact-syntax;
            tailf:cli-drop-node-name;
            key "from";
            leaf from {
              type uint32;
            }
            leaf to {
              tailf:cli-drop-node-name;
              type uint32;
            }
          }
        }
      }
    }
    container no-switchport {
      tailf:cli-drop-node-name;
      leaf switchport {
        type boolean;
      }
    }
  }

  grouping interface-isis-grouping {
    container isis {
      leaf enable {
        type string;
      }
      leaf hello-interval {
        type uint16;
      }
      leaf hello-multiplier {
        type uint16;
      }
      leaf bfd {
        type boolean;
      }
      leaf circuit-type {
        type enumeration {
          enum level-1;
          enum level-1-2;
          enum level-2;
        }
      }
      container ipv6 {
        leaf metric {
          type union {
            type enumeration {
              enum maximum;
            }
            type uint32;
          }
        }
      }
      leaf metric {
        type uint32;
      }
      leaf network {
        type enumeration {
          enum point-to-point;
        }
      }
      leaf passive {
        type empty;
      }
      container authentication {
        container mode {
          container md5 {
            presence "true";
            leaf level {
              tailf:cli-drop-node-name;
              type authentication-level-type;
            }
          }
          container text {
            presence "true";
            leaf level {
              tailf:cli-drop-node-name;
              type authentication-level-type;
            }
          }
        }
        container key {
          tailf:cli-compact-syntax;
          tailf:cli-sequence-commands {
            tailf:cli-reset-siblings;
          }
          leaf encrypt {
            tailf:cli-drop-node-name;
            tailf:cli-optional-in-sequence;
            type enumeration {
              enum 0;
              enum 7;
            }
          }
          leaf string {
            tailf:cli-drop-node-name;
            type string;
          }
        }
      }
    }
  }

  grouping interface-ethernet-port-channel-common-grouping {
    container bfd {
      container interval {
        tailf:cli-compact-syntax;
        tailf:cli-sequence-commands {
          tailf:cli-reset-siblings;
        }
        leaf transmit-rate {
          tailf:cli-drop-node-name;
          type uint32;
        }
        choice min-rx-choice {
          leaf min_rx {
            type uint32;
          }
          leaf min-rx {
            type uint32;
          }
        }
        leaf multiplier {
          type uint8;
        }
      }
      leaf echo {
        type empty;
      }
    }
    container bgp {
      container session {
        leaf tracker {
          type string;
        }
      }
    }
    container evpn {
      container ethernet-segment {
        tailf:cli-add-mode;
        leaf identifier {
          type string;
        }
        container designated-forwarder {
          container election {
            container algorithm {
              leaf preference {
                type uint16;
              }
            }
          }
        }
        container route-target {
          leaf import {
            type string;
          }
        }
      }
    }
    uses interface-isis-grouping;
    container l2-protocol {
      container forwarding {
        leaf profile {
          type string;
        }
      }
    }
    container mpls {
      container ldp {
        leaf interface {
          type empty;
        }
        leaf igp {
          type enumeration {
            enum sync;
          }
        }
      }
    }
    container telemetry {
      container inband {
        container profile {
          choice telemetry-inband-profile-choice {
            leaf core {
              type string;
            }
            leaf edge {
              type string;
            }
          }
        }
      }
    }
    container ptp {
      leaf enable {
        type empty;
      }
      container announce {
        leaf interval {
          type int8;
        }
        leaf timeout {
          type uint8;
        }
      }
      container delay-req {
        leaf interval {
          type int8;
        }
      }
      leaf local-priority {
        type uint8;
      }
      leaf role {
        type enumeration {
          enum dynamic;
          enum master;
        }
      }
      leaf transport {
        type enumeration {
          enum ipv4;
          enum ipv6;
          enum layer2;
        }
      }
      container sync-message {
        leaf interval {
          type int8;
        }
      }
      leaf-list vlan {
        tailf:cli-range-list-syntax;
        type uint16;
      }
    }
    container qos {
      leaf cos {
        type uint8;
      }
      leaf trust {
        type enumeration {
          enum cos;
          enum dscp;
        }
      }
    }
    leaf service-profile {
      type string;
    }
    container sflow {
      leaf enable {
        type boolean;
      }
    }
    container shape {
      container rate {
        tailf:cli-compact-syntax;
        tailf:cli-sequence-commands;
        leaf value {
          tailf:cli-drop-node-name;
          type uint32;
        }
        container burst-size {
          tailf:cli-compact-syntax;
          tailf:cli-flatten-container;
          tailf:cli-sequence-commands {
            tailf:cli-reset-siblings;
          }
          leaf value {
            tailf:cli-drop-node-name;
            type union {
              type uint32;
              type uint16;
              type uint32;
            }
          }
          choice burst-size-choice {
            leaf kbytes {
              type empty;
            }
            leaf mbytes {
              type empty;
            }
            leaf bytes {
              type empty;
            }
          }
        }
      }
    }
    list tx-queue {
      key "id";
      leaf id {
        type uint8;
      }
      leaf priority {
        type enumeration {
          enum strict;
        }
      }
      container bandwidth {
        leaf percent {
          type uint8;
        }
      }
    }
    container vlan {
      leaf id {
        type uint16;
      }
    }
    uses interface-mac-grouping;
    uses interface-spanning-tree-grouping;
  }

  grouping interface-spanning-tree-grouping {
    container spanning-tree {
      leaf mode {
        type enumeration {
          enum backup;
          enum mstp;
          enum none;
          enum rapid-pvst;
          enum rstp;
        }
      }
      leaf bpdufilter {
        type enumeration {
          enum disable {
            tailf:code-name "bdufilter_disable";
          }
          enum enable {
            tailf:code-name "bdufilter_enable";
          }
        }
      }
      container bpduguard {
        leaf value {
          tailf:cli-drop-node-name;
          type enumeration {
            enum disable;
            enum enable;
          }
        }
        container rate-limit {
          leaf value {
            tailf:cli-drop-node-name;
            type enumeration {
              enum disable;
              enum enable;
            }
          }
          container count {
            tailf:cli-compact-syntax;
            tailf:cli-sequence-commands;
            leaf value {
              tailf:cli-drop-node-name;
              type uint16;
            }
            leaf interval {
              type uint8;
            }
          }
        }
      }
      leaf cost {
        type spanning-tree-cost-type;
      }
      leaf guard {
        type enumeration {
          enum loop;
          enum none;
          enum root;
        }
      }
      leaf link-type {
        type enumeration {
          enum point-to-point;
          enum shared;
        }
      }
      container mst {
        list port {
          tailf:cli-drop-node-name;
          tailf:cli-suppress-mode;
          key "range";
          leaf range {
            type string;
          }
          leaf cost {
            type mst-cost-type;
          }
          leaf port-priority {
            type uint8;
          }
        }
        leaf pre-standard {
          type empty;
        }
        container simulate {
          container pvst {
            presence "Enable PVST simulation";
            leaf disable {
              type empty;
            }
          }
        }
      }
      container port {
        tailf:cli-sequence-commands {
          tailf:cli-reset-siblings;
        }
        tailf:cli-compact-syntax;
        leaf type {
          type enumeration {
            enum edge;
            enum network;
            enum normal;
          }
        }
        leaf trunk {
          type empty;
        }
      }
      container portfast {
        tailf:cli-compact-syntax;
        presence "true";
        leaf portfast {
          tailf:cli-drop-node-name;
          type enumeration {
            enum auto;
            enum edge;
            enum network;
            enum normal;
          }
        }
      }
      leaf port-priority {
        type uint8;
      }
    }
  }

  grouping ethernet-settings-grouping {
    container bandwidth {
      tailf:cli-sequence-commands {
        tailf:cli-reset-siblings;
      }
      tailf:cli-compact-syntax;
      leaf inherit {
        tailf:cli-optional-in-sequence;
        type empty;
      }
      leaf bandwidth {
        tailf:cli-drop-node-name;
        type uint32;
      }
    }
    leaf beacon {
      type empty;
    }
    leaf description {
      tailf:cli-multi-value;
      type string;
    }
    leaf cdp {
      type enumeration {
        enum enable {
          tailf:code-name "ethernet-settings-grouping_cdp_enable";
        }
      }
    }
    uses interface-encapsulation-grouping;
    container channel-group {
      tailf:cli-sequence-commands {
        tailf:cli-reset-siblings;
      }
      tailf:cli-compact-syntax;
      leaf id {
        tailf:cli-drop-node-name;
        type uint16;
      }
      leaf mode {
        type enumeration {
          enum active;
          enum on;
          enum passive {
            tailf:code-name "mode_passive";
          }
        }
      }
    }
    leaf delay {
      type uint32;
    }
    container fex {
      leaf associate {
        type uint8;
      }
    }
    container flowcontrol {
      leaf receive {
        type enumeration {
          enum off {
            tailf:code-name "flowcontrol_off";
          }
          enum on {
            tailf:code-name "flowcontrol_on";
          }
        }
      }
      leaf send {
        type enumeration {
          enum off {
            tailf:code-name "send_off";
          }
          enum on {
            tailf:code-name "send_on";
          }
        }
      }
    }
    container inherit {
      leaf port-profile {
        type string;
      }
    }
    uses switchport-interface-grouping;
    container vrf {
      choice vrf-choice {
        leaf forwarding {
          type string;
        }
        leaf name {
          tailf:cli-drop-node-name;
          type string;
        }
      }
      leaf member {
        type vrf-member-type;
      }
    }
    container ip {
      uses interface-ip-address-grouping;
      container igmp-alone {
        tailf:cli-drop-node-name;
        leaf igmp {
          type empty;
        }
      }
      container igmp {
        leaf version {
          type uint8;
        }
        container static-group {
          list multicast {
            tailf:cli-drop-node-name;
            tailf:cli-suppress-mode;
            key "address";
            leaf address {
              type inet:ipv4-address;
            }
          }
          list acl {
            tailf:cli-suppress-mode;
            key "name";
            leaf name {
              type string;
            }
          }
        }
        leaf router-alert {
          type enumeration {
            enum mandatory;
            enum optional;
          }
        }
        container snooping {
          leaf filter {
            type string;
          }
        }
      }
      uses access-group-list-grouping;
      uses interface-ip-ospf-grouping;
      uses interface-ip-proxy-arp-grouping;
      uses interface-ip-nat-grouping;
