  container l2-protocol {
    tailf:cli-add-mode;
    container forwarding {
      list profile {
        key "name";
        leaf name {
          type string;
        }
        container lacp {
          leaf forward {
            type empty;
          }
        }
        container lldp {
          leaf forward {
            type empty;
          }
        }
        container stp {
          leaf forward {
            type empty;
          }
        }
      }
    }
  }
  container queue-monitor {
    container default-length {
      tailf:cli-drop-node-name;
      leaf length {
        type boolean;
      }
    }
    container length {
      leaf update-interval {
        type uint32;
      }
      leaf notifying {
        type empty;
      }
    }
    container streaming {
      tailf:cli-add-mode;
      leaf shutdown {
        type boolean;
      }
      container ip {
        uses access-group-grouping;
      }
      container ipv6 {
        uses access-group-grouping;
      }
    }
  }
  container radius-server {
    leaf deadtime {
      type uint16;
    }
    leaf directed-request {
      type empty;
    }
    list host {
      tailf:cli-suppress-mode;
      tailf:cli-delete-when-empty;
      tailf:cli-compact-syntax;
      ordered-by user;
      key "id";
      leaf id {
        type union {
          type inet:ip-address;
          type string;
        }
      }
      leaf auth-port {
        type uint16;
      }
      leaf acct-port {
        type uint16;
      }
      container key {
        tailf:cli-flatten-container;
        tailf:cli-compact-syntax;
        tailf:cli-sequence-commands;
        leaf encryption {
          tailf:cli-drop-node-name;
          tailf:cli-optional-in-sequence;
          type enumeration {
            enum 0;
            enum 7;
          }
        }
        leaf password {
          tailf:cli-drop-node-name;
          type string;
        }
      }
      leaf authentication {
        type empty;
      }
      leaf accounting {
        type empty;
      }
      leaf retransmit {
        type uint8;
      }
      leaf timeout {
        type uint8;
      }
    }
    container key {
      tailf:cli-compact-syntax;
      tailf:cli-sequence-commands;
      leaf encryption {
        tailf:cli-drop-node-name;
        tailf:cli-optional-in-sequence;
        type enumeration {
          enum 0;
          enum 7;
        }
      }
      leaf password {
        tailf:cli-drop-node-name;
        type string;
      }
    }
    leaf retransmit {
      type uint8;
    }
    leaf timeout {
      type uint16;
    }
  }
  container snmp-server {
