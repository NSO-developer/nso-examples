            tailf:cli-drop-node-name;
            tailf:cli-optional-in-sequence;
            type enumeration {
              enum 0;
              enum 7;
              enum 8a;
            }
          }
          leaf auth-key {
            tailf:cli-drop-node-name;
            type string;
          }
        }
      }
      leaf mtu-ignore {
        type empty;
      }
      leaf network {
        type enumeration {
          enum point-to-point;
        }
