          }
          leaf vrf {
            tailf:cli-expose-key-name;
            type string;
          }
        }
      }
    }
    list host {
      tailf:cli-suppress-mode;
      tailf:cli-delete-when-empty;
      tailf:cli-compact-syntax;
      tailf:cli-sequence-commands {
        tailf:cli-reset-all-siblings;
      }
      key "ip-address";
      leaf ip-address {
        tailf:cli-case-sensitive;
        type host-type;
      }
      leaf message-type {
        tailf:cli-optional-in-sequence;
        tailf:cli-drop-node-name;
        type enumeration {
          enum informs;
          enum traps;
        }
      }
      container version {
        tailf:cli-optional-in-sequence;
        tailf:cli-flatten-container;
        tailf:cli-compact-syntax;
        leaf version {
          tailf:cli-drop-node-name;
          type enumeration {
            enum 1;
            enum 2c;
            enum 3;
          }
        }
        leaf security-level {
          tailf:cli-drop-node-name;
          type enumeration {
            enum auth;
            enum noauth;
            enum priv;
          }
        }
      }
      leaf community-string {
        tailf:cli-drop-node-name;
        type string;
      }
    }
    container host-vrf {
      tailf:cli-drop-node-name;
      list host {
        tailf:cli-suppress-mode;
        tailf:cli-delete-when-empty;
        tailf:cli-compact-syntax;
        key "ip-address vrf message-type";
        leaf ip-address {
          type inet:host;
        }
        leaf vrf {
          tailf:cli-expose-key-name;
          type string;
        }
        leaf message-type {
          type enumeration {
            enum informs;
            enum traps;
          }
        }
        list version {
          tailf:cli-suppress-mode;
          tailf:cli-compact-syntax;
          key "name community";
          leaf name {
            type enumeration {
              enum 1;
              enum 2c;
              enum 3;
            }
          }
          leaf community {
            type string;
          }
          list udp-port {
            tailf:cli-suppress-mode;
            tailf:cli-compact-syntax;
            key "port";
            leaf port {
              type uint16;
            }
            leaf security-level {
              tailf:cli-drop-node-name;
              type enumeration {
                enum auth;
                enum noauth;
                enum priv;
              }
            }
          }
          leaf security-level {
            tailf:cli-drop-node-name;
            tailf:cli-prefix-key {
              tailf:cli-before-key "2";
            }
            type enumeration {
              enum auth;
              enum noauth;
              enum priv;
            }
          }
        }
      }
    }
    leaf location {
      tailf:cli-multi-value;
      type string;
    }
    container vrf {
      list vrf-list {
        tailf:cli-drop-node-name;
        tailf:cli-suppress-mode;
        key "name";
        leaf name {
          type string;
        }
      }
      list vrf-local-interface-list {
        tailf:cli-drop-node-name;
        tailf:cli-suppress-mode;
        tailf:cli-delete-when-empty;
        key "name";
        leaf name {
          type string;
        }
        container local-interface {
          uses interface-grouping;
        }
      }
      leaf default {
        type boolean;
      }
    }
  }
  container no-spanning-tree {
    choice no-spanning-tree-vlan-choice {
      list vlan {
        tailf:cli-suppress-mode;
        tailf:cli-range-list-syntax;
        key "id";
        leaf id {
          type uint32;
        }
      }
      list vlan-id {
        tailf:cli-suppress-mode;
        tailf:cli-range-list-syntax;
        key "id";
        leaf id {
          type uint32;
        }
      }
    }
  }
  container spanning-tree {
    container edge-port {
      container bpduguard {
        leaf default {
          type empty;
        }
      }
      container bpdufilter {
        leaf default {
          type empty;
        }
      }
    }
    container guard {
      container loop {
        leaf default {
          type empty;
        }
      }
    }
    leaf mode {
      type enumeration {
        enum backup;
        enum mstp;
        enum none;
        enum rapid-pvst;
        enum rstp;
      }
    }
    container mst {
      container pvst {
        leaf border {
          type empty;
        }
      }
      list mst-instances {
        tailf:cli-drop-node-name;
        tailf:cli-suppress-mode;
        tailf:cli-range-list-syntax;
        key "instance";
        leaf instance {
          type uint16;
        }
        leaf priority {
          type uint16;
        }
      }
      container configuration {
        tailf:cli-add-mode;
        leaf name {
          type string;
        }
        leaf revision {
          type uint32;
        }
        list instance {
          tailf:cli-suppress-mode;
          tailf:cli-range-list-syntax;
          tailf:cli-sequence-commands;
          key "vlan";
          leaf instance-id {
            tailf:cli-drop-node-name;
            tailf:cli-prefix-key;
            type uint16;
          }
          leaf vlan {
            tailf:cli-expose-key-name;
            type uint16;
          }
        }
      }
    }
    container portfast {
      leaf bpdufilter {
        type enumeration {
          enum default;
        }
      }
      leaf bpduguard {
        type enumeration {
          enum default;
        }
      }
    }
    container vlan {
      list vlan-list {
        tailf:cli-drop-node-name;
        tailf:cli-suppress-mode;
        tailf:cli-range-list-syntax;
        key "id";
        leaf id {
          type uint32;
        }
        leaf priority {
          type uint32;
        }
      }
    }
    container vlan-id {
      list vlan-list {
        tailf:cli-drop-node-name;
        tailf:cli-suppress-mode;
        tailf:cli-range-list-syntax;
        key "id";
        leaf id {
          type uint32;
        }
        leaf priority {
          type uint32;
        }
      }
    }
  }
  container switch {
    leaf forwarding-mode {
      type enumeration {
        enum cut-through;
        enum store-and-forward;
      }
    }
  }
  container switchport {
    container default {
      leaf mode {
        type enumeration {
          enum access;
          enum routed;
        }
      }
    }
  }
  container service {
    container interface {
      container inactive {
        container port-id {
          container allocation {
            leaf disabled {
              type empty;
            }
          }
        }
      }
    }
    container unsupported-transceiver {
      tailf:cli-compact-syntax;
      tailf:cli-sequence-commands {
        tailf:cli-reset-siblings;
      }
      leaf licensee {
        tailf:cli-drop-node-name;
        type string;
      }
      leaf key {
        tailf:cli-drop-node-name;
        type string;
      }
    }
    container running-config {
      leaf timestamp {
        type empty;
      }
    }
    container routing {
      container protocols {
        leaf model {
          type enumeration {
            enum multi-agent;
            enum ribd;
          }
        }
      }
    }
  }
  container mlag {
    container configuration {
      tailf:cli-add-mode;
      leaf domain-id {
        type string;
      }
      container dual-primary {
        container detection {
          tailf:cli-compact-syntax;
          tailf:cli-sequence-commands;
          leaf delay {
            type uint32;
          }
          container action {
            tailf:cli-flatten-container;
            leaf errdisable {
              type enumeration {
                enum all-interfaces;
              }
            }
          }
        }
      }
      container heartbeat-interval {
        leaf disabled {
          type empty;
        }
        leaf values {
          tailf:cli-drop-node-name;
          type uint16;
        }
      }
      container local-interface {
        leaf Vlan {
          tailf:cli-allow-join-with-value;
          type uint16;
        }
      }
      container peer-address {
        leaf ip {
          tailf:cli-drop-node-name;
          type inet:ipv4-address;
        }
        container heartbeat {
          tailf:cli-compact-syntax;
          tailf:cli-sequence-commands {
            tailf:cli-reset-siblings;
          }
          leaf ip {
            tailf:cli-drop-node-name;
            type inet:ipv4-address;
          }
          leaf vrf {
            type string;
          }
        }
      }
      container peer-link {
        leaf Ethernet {
          tailf:cli-allow-join-with-value;
          type string;
        }
        leaf Port-Channel {
          tailf:cli-allow-join-with-value;
          type string;
        }
      }
      container reload-delay {
        leaf infinity {
          type empty;
        }
        container mlag {
          leaf infinity {
            type empty;
          }
          leaf seconds {
            tailf:cli-drop-node-name;
            type uint32;
          }
        }
        container non-mlag {
          leaf infinity {
            type empty;
          }
          leaf seconds {
            tailf:cli-drop-node-name;
            type uint32;
          }
        }
        leaf seconds {
          tailf:cli-drop-node-name;
          type uint32;
        }
      }
      leaf shutdown {
        type empty;
      }
    }
  }
  leaf prompt {
    type string;
  }
  container qos {
    tailf:cli-compact-syntax;
    container map {
      tailf:cli-compact-syntax;
      list cos {
        tailf:cli-range-list-syntax;
        tailf:cli-suppress-mode;
        tailf:cli-delete-when-empty;
        key "name";
        leaf name {
          type uint8;
        }
        container to {
          leaf traffic-class {
            type uint8;
          }
        }
      }
      list dscp {
        tailf:cli-range-list-syntax;
        tailf:cli-suppress-mode;
        tailf:cli-delete-when-empty;
        key "name";
        leaf name {
          type uint8;
        }
        container to {
          leaf traffic-class {
            type uint8;
          }
        }
      }
    }
    list profile {
      key "name";
      leaf name {
        type string;
      }
      container qos {
        leaf cos {
          type uint8;
        }
      }
      container shape {
        container rate {
          choice qos-profile-choice {
            container rate-percent {
              tailf:cli-drop-node-name;
              tailf:cli-compact-syntax;
              leaf rate {
                tailf:cli-drop-node-name;
                type uint8;
              }
              leaf percent {
                type empty;
              }
            }
            container rate-kbps {
              tailf:cli-drop-node-name;
              tailf:cli-compact-syntax;
              leaf rate {
                tailf:cli-drop-node-name;
                type uint32;
              }
            }
          }
        }
      }
    }
    container rewrite {
      leaf cos {
        type boolean;
      }
      leaf dscp {
        type empty;
      }
    }
  }
  container traffic-policies {
    tailf:cli-add-mode;
    container cpu {
      tailf:cli-add-mode;
      tailf:cli-compact-syntax;
      tailf:cli-sequence-commands;
      presence "true";
      leaf traffic-policy {
        tailf:cli-hide-in-submode;
        type string;
      }
      leaf vrf {
        tailf:cli-hide-in-submode;
        type enumeration {
          enum all;
        }
      }
      container enforcement {
        leaf management {
          type empty;
        }
      }
    }
    container field-set {
      list ipv4 {
        key "prefix";
        leaf prefix {
          tailf:cli-expose-key-name;
          type string;
        }
        leaf-list prefixes {
          tailf:cli-drop-node-name;
          tailf:cli-flat-list-syntax;
          type inet:ipv4-prefix;
        }
      }
      list ipv6 {
        key "prefix";
        leaf prefix {
          tailf:cli-expose-key-name;
          type string;
        }
        leaf-list prefixes {
          tailf:cli-drop-node-name;
          tailf:cli-flat-list-syntax;
          type inet:ipv6-prefix;
        }
      }
    }
    list traffic-policy {
      key "name";
      leaf name {
        type string;
      }
      list match {
        tailf:cli-delete-when-empty;
        tailf:cli-sequence-commands;
        key "name";
        leaf name {
          type string;
        }
        leaf proto {
          tailf:cli-drop-node-name;
          tailf:cli-hide-in-submode;
          type enumeration {
            enum ipv4;
            enum ipv6;
          }
        }
        container destination {
          tailf:cli-break-sequence-commands;
          container prefix {
            leaf-list field-set {
              tailf:cli-flat-list-syntax;
              type string;
            }
          }
        }
        container source {
          container prefix {
            leaf-list field-set {
              tailf:cli-flat-list-syntax;
              type string;
            }
          }
        }
        container protocol {
          container tcp {
            container source {
              list port {
                tailf:cli-suppress-mode;
                tailf:cli-delete-when-empty;
                key "name";
                leaf name {
                  tailf:cli-multi-word-key;
                  type string;
                }
                container destination {
                  leaf-list port {
                    tailf:cli-flat-list-syntax;
                    type string;
                  }
                }
              }
            }
          }
          container udp {
            container source {
              list port {
                tailf:cli-suppress-mode;
                tailf:cli-delete-when-empty;
                key "name";
                leaf name {
                  tailf:cli-multi-word-key;
                  type string;
                }
                container destination {
                  leaf-list port {
                    tailf:cli-flat-list-syntax;
                    type string;
                  }
                }
              }
            }
          }
          container icmp {
            presence "true";
            uses protocol-icmp-grouping;
          }
          container icmpv6 {
            presence "true";
            uses protocol-icmp-grouping;
          }
          container igmp {
            presence "true";
          }
          container neighbors {
            leaf bgp {
              type empty;
            }
          }
        }
        leaf-list ttl {
          tailf:cli-range-list-syntax;
          type uint16;
        }
        container actions {
          tailf:cli-add-mode;
          container count {
            presence "true";
            leaf name {
              tailf:cli-drop-node-name;
              type string;
            }
          }
          leaf drop {
            type empty;
          }
          container police {
            container rate {
              tailf:cli-compact-syntax;
              tailf:cli-sequence-commands {
                tailf:cli-reset-siblings;
              }
              leaf value {
                tailf:cli-drop-node-name;
                type uint64;
              }
              leaf units {
                tailf:cli-drop-node-name;
                type enumeration {
                  enum bps;
                  enum burst-size;
                  enum gbps;
                  enum kbps;
                  enum mbps;
                }
              }
            }
          }
        }
      }
    }
  }
}
