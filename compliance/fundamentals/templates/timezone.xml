<compliance xmlns="http://tail-f.com/ns/ncs">
  <template>
    <name>timezone</name>
    <ned-id>
      <id xmlns:cisco-iosxr-netsim-cli-1.0="http://tail-f.com/ns/ned-id/cisco-iosxr-netsim-cli-1.0">
      cisco-iosxr-netsim-cli-1.0:cisco-iosxr-netsim-cli-1.0</id>
      <config>
        <clock xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <timezone>
            <zone>{$TIMEZONE}</zone>
            <hours-offset>{$OFFSET_HOURS}</hours-offset>
            <minutes-offset>{$OFFSET_MINUTES}</minutes-offset>
          </timezone>
        </clock>
      </config>
    </ned-id>
    <ned-id>
      <id xmlns:cisco-ios-netsim-cli-1.0="http://tail-f.com/ns/ned-id/cisco-ios-netsim-cli-1.0">
      cisco-ios-netsim-cli-1.0:cisco-ios-netsim-cli-1.0</id>
      <config>
        <clock xmlns="urn:ios">
          <timezone>
            <zone>{$TIMEZONE}</zone>
            <hours>{$OFFSET_HOURS}</hours>
            <minutes>{$OFFSET_MINUTES}</minutes>
          </timezone>
        </clock>
      </config>
    </ned-id>
  </template>
</compliance>
