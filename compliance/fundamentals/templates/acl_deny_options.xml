<compliance xmlns="http://tail-f.com/ns/ncs">
  <template>
    <name>acl_deny_options</name>
    <description>Ensure routers explicitly block all IP packets containing any IP options. Prevent DoS attacks by dropping potentially malicious or resource-intensive packets.</description>
    <ned-id>
      <id xmlns:cisco-ios-netsim-cli-1.0="http://tail-f.com/ns/ned-id/cisco-ios-netsim-cli-1.0">
      cisco-ios-netsim-cli-1.0:cisco-ios-netsim-cli-1.0</id>
      <config>
        <ip xmlns="urn:ios">
          <access-list>
            <extended>
              <ext-named-acl>
                <name>{$IPV4_PROTECT}</name>
                <ext-access-list-rule>
                  <rule>.*deny ip any any option any-options</rule>
                </ext-access-list-rule>
              </ext-named-acl>
            </extended>
          </access-list>
        </ip>
      </config>
    </ned-id>
  </template>
</compliance>
