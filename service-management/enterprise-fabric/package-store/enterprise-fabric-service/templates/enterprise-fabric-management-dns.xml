<config-template xmlns="http://tail-f.com/ns/config/1.0">
  <devices xmlns="http://tail-f.com/ns/ncs">
    <device>
      <name>{$DEVICE}</name>
      <config>
        <ip xmlns="urn:ios">
          <name-server>
            <name-server-list>
              <address>{$DNS_SERVER}</address>
            </name-server-list>
          </name-server>
        </ip>
        <configuration xmlns="http://xml.juniper.net/xnm/1.1/xnm">
          <system>
            <name-server>
              <name>{$DNS_SERVER}</name>
            </name-server>
          </system>
        </configuration>
      </config>
    </device>
  </devices>
</config-template>
