<config-template xmlns="http://tail-f.com/ns/config/1.0">
  <devices xmlns="http://tail-f.com/ns/ncs">
    <device>
      <name>{$DEVICE}</name>
      <config>
        <ip xmlns="urn:ios">
          <route>
            <ip-route-forwarding-list>
              <prefix>0.0.0.0</prefix>
              <mask>0.0.0.0</mask>
              <forwarding-address>{$NEXT_HOP}</forwarding-address>
            </ip-route-forwarding-list>
          </route>
        </ip>
      </config>
    </device>
  </devices>
</config-template>
