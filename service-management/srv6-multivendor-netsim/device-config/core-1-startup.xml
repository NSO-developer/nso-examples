<?xml version="1.0"?>
<config xmlns="http://tail-f.com/ns/config/1.0">
  <system xmlns="http://tail-f.com/ned/alu-sr">
    <name>core-1</name>
    <alarms>
      <shutdown>false</shutdown>
    </alarms>
    <snmp>
      <shutdown>false</shutdown>
      <streaming>
        <shutdown>true</shutdown>
      </streaming>
    </snmp>
    <lldp>
      <shutdown>false</shutdown>
    </lldp>
    <netconf>
      <shutdown>false</shutdown>
    </netconf>
    <time>
      <ntp>
        <shutdown>false</shutdown>
        <authentication-check>false</authentication-check>
      </ntp>
      <zone>
        <name>UTC</name>
      </zone>
    </time>
    <security>
      <management>
        <allow-ssh>true</allow-ssh>
        <allow-netconf>true</allow-netconf>
      </management>
      <cpm-filter>
        <ip-filter>
          <shutdown>false</shutdown>
        </ip-filter>
        <ipv6-filter>
          <shutdown>false</shutdown>
        </ipv6-filter>
      </cpm-filter>
      <management-access-filter>
        <ip-filter>
          <shutdown>false</shutdown>
        </ip-filter>
        <ipv6-filter>
          <shutdown>false</shutdown>
        </ipv6-filter>
      </management-access-filter>
      <password>
        <admin-password>
          <password>admin</password>
        </admin-password>
      </password>
    </security>
  </system>
  <port xmlns="http://tail-f.com/ned/alu-sr">
    <port-id>1/1/1</port-id>
    <description>to core-2 Gi0/0/0/2</description>
    <ethernet>
      <mode>network</mode>
      <mtu>9194</mtu>
    </ethernet>
  </port>
  <port xmlns="http://tail-f.com/ned/alu-sr">
    <port-id>1/1/2</port-id>
    <description>to core-2 Gi0/0/0/3</description>
    <ethernet>
      <mode>network</mode>
      <mtu>9194</mtu>
    </ethernet>
  </port>
  <port xmlns="http://tail-f.com/ned/alu-sr">
    <port-id>1/1/3</port-id>
    <description>to core-4 Gi0/0/0/0</description>
    <ethernet>
      <mode>network</mode>
      <mtu>9194</mtu>
    </ethernet>
  </port>
  <port xmlns="http://tail-f.com/ned/alu-sr">
    <port-id>1/1/4</port-id>
    <description>to core-4 Gi0/0/0/1</description>
    <ethernet>
      <mode>network</mode>
      <mtu>9194</mtu>
    </ethernet>
  </port>
  <port xmlns="http://tail-f.com/ned/alu-sr">
    <port-id>1/1/5</port-id>
    <description>to pe-01 xe-0/0/0:0</description>
    <ethernet>
      <mode>network</mode>
      <mtu>9194</mtu>
    </ethernet>
  </port>
  <port xmlns="http://tail-f.com/ned/alu-sr">
    <port-id>1/1/6</port-id>
    <description>to core-5 Gi0/0/0/0</description>
    <ethernet>
      <mode>network</mode>
      <mtu>9194</mtu>
    </ethernet>
  </port>
  <router xmlns="http://tail-f.com/ned/alu-sr">
    <router-name>Base</router-name>
    <autonomous-system>65000</autonomous-system>
    <router-id>10.10.20.101</router-id>
    <interface>
      <interface-name>system</interface-name>
      <description>Router ID / management loopback</description>
      <icmp>
        <mask-reply>false</mask-reply>
      </icmp>
      <address>10.10.20.101/32</address>
      <ipv6>
        <address>
          <addr>fd00::1/128</addr>
        </address>
      </ipv6>
      <shutdown>false</shutdown>
    </interface>
    <static-route>
      <route>0.0.0.0/0</route>
      <next-hop>
        <address>10.10.20.254</address>
      </next-hop>
    </static-route>
    <mpls>
      <shutdown>true</shutdown>
    </mpls>
    <rsvp>
      <shutdown>true</shutdown>
    </rsvp>
  </router>
</config>
