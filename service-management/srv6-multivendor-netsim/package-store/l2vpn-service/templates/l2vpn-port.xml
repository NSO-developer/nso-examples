<config-template xmlns="http://tail-f.com/ns/config/1.0">
  <devices xmlns="http://tail-f.com/ns/ncs">
    <device>
      <name>{$PE}</name>
      <config>
        <interface xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <GigabitEthernet tags="replace">
            <id>{$INTERFACE_NO}</id>
            <l2transport/>
            <shutdown tags="delete"/>
          </GigabitEthernet>
        </interface>
        <evpn xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <evi>
            <id>{$VNI}</id>
            <segment-routing>srv6</segment-routing>
            <advertise-mac/>
          </evi>
          <interface>
            <name>GigabitEthernet{$INTERFACE_NO}</name>
          </interface>
        </evpn>
        <l2vpn xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <bridge>
            <group>
              <group-name>EVPN-{$CUSTOMER}</group-name>
              <bridge-domain>
                <bridge-domain-name>{$VNI}-{name}</bridge-domain-name>
                <interface>
                  <name>GigabitEthernet{$INTERFACE_NO}</name>
                </interface>
                <evi>
                  <id>{$VNI}</id>
                  <segment-routing>srv6</segment-routing>
                </evi>
              </bridge-domain>
            </group>
          </bridge>
        </l2vpn>
        <configuration xmlns="http://xml.juniper.net/xnm/1.1/xnm">
          <interfaces>
            <interface>
              <name>{$INTERFACE}</name>
              <unit tags="replace">
                <name>0</name>
                <description>{name} EVPN ELAN access</description>
                <family>
                  <ethernet-switching/>
                </family>
              </unit>
            </interface>
          </interfaces>
          <routing-instances>
            <instance>
              <name>EVPN-{name}</name>
              <description>{$CUSTOMER} EVPN ELAN over SRv6</description>
              <instance-type>mac-vrf</instance-type>
              <service-type>vlan-based</service-type>
              <interface>
                <name>{$INTERFACE}.0</name>
              </interface>
              <route-distinguisher>
                <rd-type>{$ROUTER_ID}:{$VNI}</rd-type>
              </route-distinguisher>
              <vrf-target>
                <community>target:{$AS}:{$VNI}</community>
              </vrf-target>
              <protocols>
                <evpn>
                  <encapsulation>srv6</encapsulation>
                </evpn>
              </protocols>
              <bridge-domains>
                <domain>
                  <name>BD-{name}</name>
                  <service-id>{$VNI}</service-id>
                  <interface>
                    <name>{$INTERFACE}.0</name>
                  </interface>
                </domain>
              </bridge-domains>
            </instance>
          </routing-instances>
        </configuration>
      </config>
    </device>
  </devices>
</config-template>
