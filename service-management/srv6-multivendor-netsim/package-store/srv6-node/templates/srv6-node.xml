<config-template xmlns="http://tail-f.com/ns/config/1.0">
  <devices xmlns="http://tail-f.com/ns/ncs">
    <device>
      <name>{name}</name>
      <config>
        <?if {$USE_CDP}?>
          <cdp xmlns="http://tail-f.com/ned/cisco-ios-xr"/>
        <?end?>
        <interface xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <Loopback>
            <id>0</id>
            <ipv6>
              <address>
                <prefix-list>
                  <prefix>{$LOOPBACK_IP}/128</prefix>
                </prefix-list>
              </address>
            </ipv6>
          </Loopback>
          <Loopback>
            <id>1</id>
            <ipv6>
              <address>
                <prefix-list>
                  <prefix>{$SRV6_PREFIX}:1/128</prefix>
                </prefix-list>
              </address>
            </ipv6>
          </Loopback>
        </interface>
        <router xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <isis>
            <tag>
              <name>1</name>
              <is-type>level-2-only</is-type>
              <net>
                <id>49.0000.0000.{$INDEX_4CHAR}.00</id>
              </net>
              <log>
                <adjacency>
                  <changes/>
                </adjacency>
              </log>
              <address-family>
                <ipv6>
                  <unicast>
                    <metric-style>wide</metric-style>
                    <segment-routing>
                      <srv6>
                        <locator>
                          <name>VPNLAB</name>
                        </locator>
                      </srv6>
                    </segment-routing>
                  </unicast>
                </ipv6>
              </address-family>
              <interface>
                <name>Loopback0</name>
                <interface-type>passive</interface-type>
                <address-family>
                  <ipv6>
                    <unicast/>
                  </ipv6>
                </address-family>
              </interface>
              <interface>
                <name>Loopback1</name>
                <interface-type>passive</interface-type>
                <address-family>
                  <ipv6>
                    <unicast/>
                  </ipv6>
                </address-family>
              </interface>
            </tag>
          </isis>
        </router>
        <segment-routing xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <srv6>
            <encapsulation>
              <source-address>{$SRV6_PREFIX}:1</source-address>
            </encapsulation>
            <locators>
              <locator>
                <name>VPNLAB</name>
                <micro-segment>
                  <behavior>
                    <unode>psp-usd</unode>
                  </behavior>
                </micro-segment>
                <prefix>{$SRV6_PREFIX}:/48</prefix>
              </locator>
            </locators>
          </srv6>
        </segment-routing>
        <configuration xmlns="http://xml.juniper.net/xnm/1.1/xnm">
          <chassis>
            <network-services>enhanced-ip</network-services>
          </chassis>
          <interfaces>
            <interface>
              <name>lo0</name>
              <unit>
                <name>0</name>
                <family>
                  <iso>
                    <address>
                      <name>49.0000.0000.{$INDEX_4CHAR}.00</name>
                    </address>
                  </iso>
                  <inet6>
                    <address>
                      <name>{$LOOPBACK_IP}/128</name>
                    </address>
                  </inet6>
                </family>
              </unit>
              <unit>
                <name>1</name>
                <family>
                  <inet6>
                    <address>
                      <name>{$SRV6_PREFIX}:1/128</name>
                    </address>
                  </inet6>
                </family>
              </unit>
            </interface>
          </interfaces>
          <routing-options>
            <router-id>{$ROUTER_ID}</router-id>
            <autonomous-system>
              <as-number>{$AS}</as-number>
            </autonomous-system>
            <resolution>
              <preserve-nexthop-hierarchy/>
            </resolution>
            <source-packet-routing>
              <srv6>
                <locator>
                  <name>VPNLAB</name>
                  <algorithm>0</algorithm>
                  <address>{$SRV6_PREFIX}:/48</address>
                </locator>
              </srv6>
            </source-packet-routing>
          </routing-options>
          <protocols>
            <?if {$USE_CDP}?>
              <lldp>
                <interface>
                  <name>all</name>
                </interface>
              </lldp>
            <?end?>
            <isis>
              <level>
                <name>1</name>
                <disable/>
              </level>
              <interface>
                <name>lo0.0</name>
                <passive/>
              </interface>
              <interface>
                <name>lo0.1</name>
                <passive/>
              </interface>
              <source-packet-routing>
                <srv6>
                  <locator>
                    <name>VPNLAB</name>
                    <end-sid>
                      <name>{$SRV6_PREFIX}:1</name>
                      <flavor>
                        <psp/>
                        <usd/>
                      </flavor>
                    </end-sid>
                  </locator>
                </srv6>
              </source-packet-routing>
            </isis>
            <evpn>
              <encapsulation>srv6</encapsulation>
            </evpn>
          </protocols>
        </configuration>
        <router xmlns="http://tail-f.com/ned/alu-sr">
          <router-name>Base</router-name>
          <autonomous-system>{$AS}</autonomous-system>
          <router-id>{$ROUTER_ID}</router-id>
          <interface>
            <interface-name>system</interface-name>
            <description>Router ID / management loopback</description>
            <address>{$ROUTER_ID}/32</address>
            <ipv6>
              <address>
                <addr>{$LOOPBACK_IP}/128</addr>
              </address>
            </ipv6>
            <shutdown>false</shutdown>
          </interface>
          <interface>
            <interface-name>srv6-loopback</interface-name>
            <description>SRv6 locator source</description>
            <loopback/>
            <ipv6>
              <address>
                <addr>{$SRV6_PREFIX}:1/128</addr>
              </address>
            </ipv6>
            <shutdown>false</shutdown>
          </interface>
          <segment-routing>
            <segment-routing-v6>
              <micro-segment>
                <global-sid-entries>64</global-sid-entries>
                <block>
                  <ms-block-name>VPNLAB-BLOCK</ms-block-name>
                  <prefix>
                    <ip-prefix>{$SRV6_PREFIX}:/48</ip-prefix>
                  </prefix>
                  <static-function>
                    <max-entries>32</max-entries>
                  </static-function>
                  <shutdown>false</shutdown>
                </block>
              </micro-segment>
              <micro-segment-locator>
                <ms-locator-name>VPNLAB</ms-locator-name>
                <algorithm>0</algorithm>
                <block>VPNLAB-BLOCK</block>
                <un>
                  <srh-mode>psp-usd</srh-mode>
                  <value>1</value>
                </un>
                <shutdown>false</shutdown>
              </micro-segment-locator>
              <source-address>{$SRV6_PREFIX}:1</source-address>
            </segment-routing-v6>
          </segment-routing>
          <isis-list>
            <id>1</id>
            <level>
              <id>2</id>
              <wide-metrics-only/>
            </level>
            <level-capability>level-2</level-capability>
            <area-id>
              <id>49.0000</id>
            </area-id>
            <ipv6-routing>native</ipv6-routing>
            <interface>
              <name>system</name>
              <level>
                <id>2</id>
                <passive/>
              </level>
            </interface>
            <interface>
              <name>srv6-loopback</name>
              <level>
                <id>2</id>
                <passive/>
              </level>
            </interface>
            <segment-routing-v6>
              <micro-segment-locator>
                <ms-locator-name>VPNLAB</ms-locator-name>
                <level-capability>level-2</level-capability>
                <level>
                  <level>2</level>
                  <metric>10</metric>
                </level>
              </micro-segment-locator>
              <shutdown>false</shutdown>
            </segment-routing-v6>
          </isis-list>
        </router>
      </config>
    </device>
  </devices>
</config-template>
