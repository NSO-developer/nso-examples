<config-template xmlns="http://tail-f.com/ns/config/1.0">
  <devices xmlns="http://tail-f.com/ns/ncs">
    <device>
      <name>{name}</name>
      <config>
        <router xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <bgp>
            <bgp-no-instance>
              <id>{$AS}</id>
              <bgp>
                <router-id>{$ROUTER_ID}</router-id>
              </bgp>
              <address-family>
                <vpnv4>
                  <unicast/>
                </vpnv4>
                <l2vpn>
                  <evpn/>
                </l2vpn>
              </address-family>
              <neighbor-group>
                <name>RR</name>
                <remote-as>{$AS}</remote-as>
                <update-source>
                  <Loopback>0</Loopback>
                </update-source>
                <address-family>
                  <l2vpn>
                    <evpn/>
                  </l2vpn>
                  <vpnv4>
                    <unicast/>
                  </vpnv4>
                </address-family>
              </neighbor-group>
              <neighbor>
                <id>{rr-neighbors}</id>
                <use>
                  <neighbor-group>RR</neighbor-group>
                </use>
              </neighbor>
            </bgp-no-instance>
          </bgp>
        </router>
        <evpn xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <segment-routing>
            <srv6>
              <locator>
                <name>VPNLAB</name>
              </locator>
            </srv6>
          </segment-routing>
        </evpn>
        <configuration xmlns="http://xml.juniper.net/xnm/1.1/xnm">
          <protocols>
            <bgp>
              <source-packet-routing>
                <srv6>
                  <locator>
                    <name>VPNLAB</name>
                    <end-dt4-sid>{$SRV6_PREFIX}e003::</end-dt4-sid>
                    <end-dt6-sid>{$SRV6_PREFIX}e004::</end-dt6-sid>
                  </locator>
                </srv6>
              </source-packet-routing>
              <group>
                <name>RR</name>
                <type>internal</type>
                <local-address>{$LOOPBACK_IP}</local-address>
                <family>
                  <inet-vpn>
                    <unicast>
                      <advertise-srv6-service/>
                      <accept-srv6-service/>
                    </unicast>
                  </inet-vpn>
                  <evpn>
                    <signaling>
                      <advertise-srv6-service/>
                      <accept-srv6-service/>
                    </signaling>
                  </evpn>
                </family>
                <neighbor>
                  <name>{rr-neighbors}</name>
                  <peer-as>{$AS}</peer-as>
                </neighbor>
              </group>
            </bgp>
            <evpn>
              <encapsulation>srv6</encapsulation>
            </evpn>
          </protocols>
        </configuration>
      </config>
    </device>
  </devices>
</config-template>
