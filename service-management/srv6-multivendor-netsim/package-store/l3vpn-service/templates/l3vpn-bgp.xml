<config-template xmlns="http://tail-f.com/ns/config/1.0">
  <devices xmlns="http://tail-f.com/ns/ncs">
    <device>
      <name>{$PE}</name>
      <config>
        <route-policy xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <name>pass-all</name>
          <value>  pass&#13;&#10;</value>
        </route-policy>
        <router xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <bgp>
            <bgp-no-instance>
              <id>{$AS}</id>
              <vrf>
                <name>L3VPN-{$VNI}</name>
                <neighbor>
                  <id>{$CE_IP}</id>
                  <remote-as>{$CE_AS}</remote-as>
                  <update-source>
                    <GigabitEthernet>{$INTERFACE_NO}</GigabitEthernet>
                  </update-source>
                  <address-family>
                    <ipv4>
                      <unicast>
                        <route-policy>
                          <direction>in</direction>
                          <name>pass-all</name>
                        </route-policy>
                        <route-policy>
                          <direction>out</direction>
                          <name>pass-all</name>
                        </route-policy>
                        <as-override/>
                      </unicast>
                    </ipv4>
                  </address-family>
                </neighbor>
              </vrf>
            </bgp-no-instance>
          </bgp>
        </router>
        <configuration xmlns="http://xml.juniper.net/xnm/1.1/xnm">
          <policy-options>
            <policy-statement>
              <name>L3VPN-{name}-CE-IMPORT</name>
              <then>
                <accept/>
              </then>
            </policy-statement>
            <policy-statement>
              <name>L3VPN-{name}-CE-EXPORT</name>
              <then>
                <accept/>
              </then>
            </policy-statement>
          </policy-options>
          <routing-instances>
            <instance>
              <name>L3VPN-{name}</name>
              <protocols>
                <bgp>
                  <group>
                    <name>CE-{name}</name>
                    <type>external</type>
                    <local-address>{$PE_IP}</local-address>
                    <peer-as>{$CE_AS}</peer-as>
                    <as-override/>
                    <import>L3VPN-{name}-CE-IMPORT</import>
                    <export>L3VPN-{name}-CE-EXPORT</export>
                    <family>
                      <inet>
                        <unicast/>
                      </inet>
                    </family>
                    <neighbor>
                      <name>{$CE_IP}</name>
                    </neighbor>
                  </group>
                </bgp>
              </protocols>
            </instance>
          </routing-instances>
        </configuration>
      </config>
    </device>
  </devices>
</config-template>
