<config-template xmlns="http://tail-f.com/ns/config/1.0">
  <devices xmlns="http://tail-f.com/ns/ncs">
    <device>
      <name>{$PE}</name>
      <config>
        <vrf xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <vrf-list>
            <name>L3VPN-{$VNI}</name>
            <description>{$CUSTOMER}-{name}</description>
            <address-family>
              <ipv4>
                <unicast>
                  <import>
                    <route-target>
                      <address-list>
                        <name>{$VNI}:1</name>
                      </address-list>
                    </route-target>
                  </import>
                  <export>
                    <route-target>
                      <address-list>
                        <name>{$VNI}:1</name>
                      </address-list>
                    </route-target>
                  </export>
                </unicast>
              </ipv4>
            </address-family>
          </vrf-list>
        </vrf>
        <interface xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <GigabitEthernet tags="replace">
            <id>{$INTERFACE_NO}</id>
            <vrf>L3VPN-{$VNI}</vrf>
            <ipv4>
              <address>
                <ip>{$PE_IP}</ip>
                <mask>{$SUBNET_MASK}</mask>
              </address>
            </ipv4>
            <shutdown tags="delete"/>
          </GigabitEthernet>
        </interface>
        <router xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <bgp>
            <bgp-no-instance>
              <id>{$AS}</id>
              <vrf>
                <name>L3VPN-{$VNI}</name>
                <rd>{$AS}:{$VNI}</rd>
                <address-family>
                  <ipv4>
                    <unicast>
                      <redistribute>
                        <connected/>
                      </redistribute>
                      <segment-routing>
                        <srv6>
                          <locator>VPNLAB</locator>
                          <alloc>
                            <mode>per-vrf</mode>
                          </alloc>
                        </srv6>
                      </segment-routing>
                    </unicast>
                  </ipv4>
                </address-family>
              </vrf>
            </bgp-no-instance>
          </bgp>
        </router>
        <configuration xmlns="http://xml.juniper.net/xnm/1.1/xnm">
          <policy-options>
            <policy-statement>
              <name>L3VPN-{name}-EXP</name>
              <term>
                <name>DIRECT</name>
                <from>
                  <protocol>direct</protocol>
                </from>
                <then>
                  <community>
                    <key1>add</key1>
                    <community-name>L3VPN-{name}-RT</community-name>
                  </community>
                  <accept/>
                </then>
              </term>
              <term>
                <name>BGP</name>
                <from>
                  <protocol>bgp</protocol>
                </from>
                <then>
                  <community>
                    <key1>add</key1>
                    <community-name>L3VPN-{name}-RT</community-name>
                  </community>
                  <accept/>
                </then>
              </term>
            </policy-statement>
            <policy-statement>
              <name>L3VPN-{name}-IMP</name>
              <term>
                <name>VPN-RT</name>
                <from>
                  <community>L3VPN-{name}-RT</community>
                </from>
                <then>
                  <accept/>
                </then>
              </term>
            </policy-statement>
            <community>
              <name>L3VPN-{name}-RT</name>
              <members>target:{$AS}:{$VNI}</members>
            </community>
          </policy-options>
          <interfaces>
            <interface>
              <name>{$INTERFACE}</name>
              <unit tags="replace">
                <name>0</name>
                <description>{name} L3VPN CE attachment</description>
                <family>
                  <inet>
                    <address>
                      <name>{$PE_IP}/{$SUBNET_CIDR}</name>
                    </address>
                  </inet>
                </family>
              </unit>
            </interface>
          </interfaces>
          <routing-instances>
            <instance>
              <name>L3VPN-{name}</name>
              <description>{$CUSTOMER} L3VPN over SRv6</description>
              <instance-type>vrf</instance-type>
              <interface>
                <name>{$INTERFACE}.0</name>
              </interface>
              <route-distinguisher>
                <rd-type>{$ROUTER_ID}:{$VNI}</rd-type>
              </route-distinguisher>
              <vrf-import>L3VPN-{name}-IMP</vrf-import>
              <vrf-export>L3VPN-{name}-EXP</vrf-export>
              <vrf-table-label/>
            </instance>
          </routing-instances>
        </configuration>
      </config>
    </device>
  </devices>
</config-template>
