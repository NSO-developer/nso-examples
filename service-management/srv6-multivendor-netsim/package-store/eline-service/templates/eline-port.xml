<config-template xmlns="http://tail-f.com/ns/config/1.0">
  <devices xmlns="http://tail-f.com/ns/ncs">
    <device>
      <name>{$PE}</name>
      <config>
        <interface xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <GigabitEthernet tags="replace">
            <id>{$INTERFACE_NO}</id>
            <l2transport/>
            <shutdown tags="delete"/>
          </GigabitEthernet>
        </interface>
        <evpn xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <interface>
            <name>GigabitEthernet{$INTERFACE_NO}</name>
          </interface>
        </evpn>
        <l2vpn xmlns="http://tail-f.com/ned/cisco-ios-xr">
          <xconnect>
            <group>
              <name>ELINE-{$CUSTOMER}</name>
              <p2p>
                <name>{$VNI}-{name}</name>
                <interface>
                  <name>GigabitEthernet{$INTERFACE_NO}</name>
                </interface>
                <neighbor-evpn-service>
                  <neighbor>
                    <evpn>
                      <evi>{$VNI}</evi>
                      <service>1</service>
                      <segment-routing>
                        <srv6/>
                      </segment-routing>
                    </evpn>
                  </neighbor>
                </neighbor-evpn-service>
              </p2p>
            </group>
          </xconnect>
        </l2vpn>
        <configuration xmlns="http://xml.juniper.net/xnm/1.1/xnm">
          <interfaces>
            <interface>
              <name>{$INTERFACE}</name>
              <unit tags="replace">
                <name>0</name>
                <description>{name} EVPN-VPWS access</description>
                <family>
                  <ccc/>
                </family>
              </unit>
            </interface>
          </interfaces>
          <routing-instances>
            <instance>
              <name>EVPN-VPWS-{name}</name>
              <description>
                {$CUSTOMER} point-to-point EVPN-VPWS over SRv6
              </description>
              <instance-type>evpn-vpws</instance-type>
              <interface>
                <name>{$INTERFACE}.0</name>
              </interface>
              <route-distinguisher>
                <rd-type>{$ROUTER_ID}:{$VNI}</rd-type>
              </route-distinguisher>
              <vrf-target>
                <community>target:{$AS}:{$VNI}</community>
              </vrf-target>
              <protocols>
                <evpn>
                  <encapsulation>srv6</encapsulation>
                  <interface>
                    <name>{$INTERFACE}.0</name>
                    <vpws-service-id>
                      <local>{$VNI}</local>
                      <remote>{$VNI}</remote>
                    </vpws-service-id>
                  </interface>
                </evpn>
              </protocols>
            </instance>
          </routing-instances>
        </configuration>
      </config>
    </device>
  </devices>
</config-template>
