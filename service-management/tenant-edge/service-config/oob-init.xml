<?xml version="1.0"?>
<config xmlns="http://tail-f.com/ns/config/1.0">
  <devices xmlns="http://tail-f.com/ns/ncs">
    <global-settings>
      <confirm-network-state>
        <enabled-by-default>true</enabled-by-default>
      </confirm-network-state>
    </global-settings>
  </devices>
  <services xmlns="http://tail-f.com/ns/ncs">
    <out-of-band>
      <policy>
        <servicepoint>tenant-edge-service</servicepoint>
        <rule>
          <label>allow-xr-mtu</label>
          <path>cisco-ios-xr:interface/GigabitEthernet/mtu</path>
          <at-create>sync-from-device</at-create>
          <at-delete>sync-from-device</at-delete>
          <at-value-set>sync-from-device</at-value-set>
        </rule>
        <rule>
          <label>reject-xr-address</label>
          <path>cisco-ios-xr:interface/GigabitEthernet/ipv4/address/ip</path>
          <at-create>sync-to-device</at-create>
          <at-delete>sync-to-device</at-delete>
          <at-value-set>sync-to-device</at-value-set>
        </rule>
        <rule>
          <label>manage-xr-prefix-set</label>
          <path>cisco-ios-xr:prefix-set/set</path>
          <at-create>manage-by-service</at-create>
          <at-delete>manage-by-service</at-delete>
          <at-value-set>manage-by-service</at-value-set>
        </rule>
      </policy>
    </out-of-band>
  </services>
</config>
